# Logrotate configuration for Apex Claw
# Deploy this file to the server with:
#   scp config/logrotate/apex-claw root@104.236.193.0:/etc/logrotate.d/apex-claw
#   ssh root@104.236.193.0 'chmod 644 /etc/logrotate.d/apex-claw'

# Application logs
/var/www/apex-claw/log/*.log {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    create 0640 root root
    sharedscripts
    postrotate
        # Reopen log files by sending USR1 signal to Puma
        systemctl reload puma > /dev/null 2>&1 || true
    endscript
}

# Service logs (systemd journals handle these, but if custom log files exist)
/var/log/apex-claw/*.log {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    create 0640 root root
    sharedscripts
    postrotate
        systemctl reload puma > /dev/null 2>&1 || true
        systemctl reload solid_queue > /dev/null 2>&1 || true
    endscript
}
