# Rails configuration
RAILS_ENV=production
RAILS_MASTER_KEY=your_master_key_here
SECRET_KEY_BASE=your_secret_key_base_here
RAILS_LOG_LEVEL=info

# Primary app URL / host authorization
APP_HOST=apexclaw.local
APP_PROTOCOL=https
APP_FORCE_SSL=true
APP_ALLOWED_HOSTS=apexclaw.local,127.0.0.1,::1
MAILER_FROM=noreply@apexclaw.local

# Database configuration
# Single-database deploys can set only DATABASE_URL.
# APEX_CLAW_DB_PASSWORD is the preferred name; CLAWDECK_DB_PASSWORD remains as a legacy fallback.
APEX_CLAW_DB_PASSWORD=your_secure_database_password_here
CLAWDECK_DB_PASSWORD=your_secure_database_password_here
# NOTE: Dotenv does NOT expand ${VAR} references — set DATABASE_URL with the actual
# password value, or rely on the compose file's environment block to construct it.
DATABASE_URL=postgresql://clawdeck:your_secure_database_password_here@localhost:5432/clawdeck_production
# Optional per-role URLs for VPS installs that keep Solid Cache / Queue / Cable isolated.
CACHE_DATABASE_URL=postgresql://clawdeck:your_secure_database_password_here@localhost:5432/clawdeck_cache_production
QUEUE_DATABASE_URL=postgresql://clawdeck:your_secure_database_password_here@localhost:5432/clawdeck_queue_production
CABLE_DATABASE_URL=postgresql://clawdeck:your_secure_database_password_here@localhost:5432/clawdeck_cable_production
DB_POOL=15

# Server configuration
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2
PORT=3000
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_TO_STDOUT=true

# GitHub OAuth configuration
# Create an OAuth App at https://github.com/settings/developers
# Callback URL: https://your-domain.example/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
