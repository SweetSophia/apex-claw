<% content_for :title, "Admin Dashboard - clawdeck" %>
<% content_for :nav_center, "Admin Dashboard" %>

<section id="admin-dashboard" class="max-w-lg mx-auto space-y-6">
  <!-- Welcome message -->
  <div class="bg-stone-100 dark:bg-white/10 p-5 rounded-md">
    <h1 class="text-xl font-semibold tracking-tight text-stone-900 dark:text-stone-100 mb-2">
      Welcome, <%= current_user.email_address %>
    </h1>
    <p class="text-sm text-stone-600 dark:text-purple-100">
      Admin dashboard for ClawDeck application
    </p>
  </div>

  <!-- Stats grid -->
  <div class="grid grid-cols-2 gap-4">
    <!-- Total Users -->
    <%= link_to admin_users_path, class: "block bg-stone-100 dark:bg-white/10 p-5 rounded-md hover:bg-stone-200 dark:hover:bg-white/20 transition-colors" do %>
      <div class="text-3xl font-bold tracking-tight text-stone-900 dark:text-stone-100 mb-2">
        <%= @total_users %>
      </div>
      <div class="text-sm text-stone-600 dark:text-purple-100">
        Total Users
      </div>
    <% end %>

    <!-- Total Tasks -->
    <div class="bg-stone-100 dark:bg-white/10 p-5 rounded-md hover:bg-stone-200 dark:hover:bg-white/20 transition-colors">
      <div class="text-3xl font-bold tracking-tight text-stone-900 dark:text-stone-100 mb-2">
        <%= @total_tasks %>
      </div>
      <div class="text-sm text-stone-600 dark:text-purple-100">
        Total Tasks
      </div>
    </div>

    <!-- Recent Signups -->
    <div class="bg-stone-100 dark:bg-white/10 p-5 rounded-md hover:bg-stone-200 dark:hover:bg-white/20 transition-colors">
      <div class="text-3xl font-bold tracking-tight text-stone-900 dark:text-stone-100 mb-2">
        <%= @recent_signups %>
      </div>
      <div class="text-sm text-stone-600 dark:text-purple-100">
        Signups (7 days)
      </div>
    </div>

    <!-- Audit Logs -->
    <%= link_to admin_audit_logs_path, class: "block bg-stone-100 dark:bg-white/10 p-5 rounded-md hover:bg-stone-200 dark:hover:bg-white/20 transition-colors" do %>
      <div class="text-3xl font-bold tracking-tight text-stone-900 dark:text-stone-100 mb-2">
        <%= @total_audit_logs %>
      </div>
      <div class="text-sm text-stone-600 dark:text-purple-100">
        Audit Log Entries
      </div>
    <% end %>
  </div>

  <div class="bg-stone-100 dark:bg-white/10 p-5 rounded-md">
    <div class="flex items-center justify-between gap-3 mb-3">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-stone-600 dark:text-purple-100">Recent Audit Activity</h2>
      <%= link_to "View all", admin_audit_logs_path, class: "text-xs font-semibold text-stone-700 dark:text-stone-100 hover:underline" %>
    </div>

    <% if @recent_audit_logs.any? %>
      <div class="space-y-3">
        <% @recent_audit_logs.each do |audit_log| %>
          <div class="flex items-center justify-between gap-3 border-b border-stone-200 dark:border-white/10 pb-3 last:border-b-0 last:pb-0">
            <div>
              <div class="text-sm font-medium text-stone-900 dark:text-stone-100">
                <%= audit_log.action %> · <%= audit_log.resource_type %> #<%= audit_log.resource_id %>
              </div>
              <div class="text-xs text-stone-600 dark:text-purple-100">
                <%= audit_log.actor_type.presence || "System" %><% if audit_log.actor_id.present? %> #<%= audit_log.actor_id %><% end %> · <%= time_ago_in_words(audit_log.created_at) %> ago
              </div>
            </div>
            <div class="text-xs text-stone-500 dark:text-purple-100/70"><%= audit_log.created_at.strftime("%H:%M") %></div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-sm text-stone-600 dark:text-purple-100">No audit activity yet.</div>
    <% end %>
  </div>
</section>
