<% content_for :title, "Audit Logs - Admin - Apex Claw" %>
<% content_for :nav_center, "Audit Logs - Admin" %>

<section id="admin-audit-logs" class="space-y-0">
  <%# Forensic header with count pill %>
  <div class="bg-bg-base border-b border-white/[0.06] px-4 py-4">
    <div class="flex items-center justify-between gap-4 flex-wrap">
      <div class="flex items-center gap-3">
        <%= link_to admin_root_path, class: "text-content-secondary hover:text-content transition-colors focus-visible:ring-1 rounded" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
        <% end %>
        <div>
          <h1 class="text-lg font-semibold tracking-tight text-content">Audit Logs</h1>
          <p class="text-xs text-content-secondary">Immutable activity history for API and model-level events.</p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center rounded-full bg-accent/20 text-accent px-3 py-1 text-sm font-semibold">
          <%= @total_count %> <span class="ml-1 text-xs opacity-70">entries</span>
        </span>
      </div>
    </div>
  </div>

  <%# Sticky investigation rail %>
  <div class="sticky top-0 z-10 bg-bg-base/95 backdrop-blur border-b border-white/[0.06] px-4 py-3 space-y-3">
    <%# Quick chips row %>
    <div class="flex flex-wrap gap-2">
      <% audit_log_quick_views.each do |view| %>
        <% view_params = view[:params].transform_keys(&:to_s) %>
        <% is_active = view_params.all? { |k, v| @filters[k] == v } %>
        <%= link_to view[:label], admin_audit_logs_path(@filters.merge(view_params)),
          class: [
            "inline-flex items-center rounded px-2.5 py-1 text-xs font-semibold transition-colors focus-visible:ring-1",
            is_active ? "bg-accent text-content" : "bg-bg-elevated border border-white/[0.08] text-content-secondary hover:text-content"
          ] %>
      <% end %>
    </div>

    <%# Active filter chips %>
    <% if @filters.values.any?(&:present?) %>
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-[10px] uppercase tracking-wider text-content-muted font-semibold">Active:</span>
        <%= audit_log_filter_chips(@filters) %>
        <%= link_to "Clear all", admin_audit_logs_path,
          class: "text-[10px] uppercase tracking-wider text-content-muted hover:text-content underline focus-visible:ring-1 rounded" %>
      </div>
    <% end %>

    <%# Compact filter form %>
    <%= form_with url: admin_audit_logs_path, method: :get, local: true, class: "flex flex-wrap items-end gap-2" do |f| %>
      <div class="flex items-center gap-1">
        <%= f.label :from, class: "text-[10px] uppercase tracking-wider text-content-muted font-semibold" %>
        <%= f.date_field :from, value: @filters["from"],
          class: "rounded bg-bg-elevated border border-white/[0.08] px-2 py-1 text-xs text-content focus-visible:ring-1 focus:outline-none" %>
      </div>
      <div class="flex items-center gap-1">
        <%= f.label :to, class: "text-[10px] uppercase tracking-wider text-content-muted font-semibold" %>
        <%= f.date_field :to, value: @filters["to"],
          class: "rounded bg-bg-elevated border border-white/[0.08] px-2 py-1 text-xs text-content focus-visible:ring-1 focus:outline-none" %>
      </div>
      <div>
        <%= f.select :audit_action, options_for_select([["All actions", ""]] + @available_actions.map { |v| [v.titleize, v] }, @filters["audit_action"]),
          {}, class: "rounded bg-bg-elevated border border-white/[0.08] px-2 py-1 text-xs text-content focus-visible:ring-1 focus:outline-none" %>
      </div>
      <div>
        <%= f.select :actor_type, options_for_select([["All actors", ""]] + @available_actor_types.map { |v| [v, v] }, @filters["actor_type"]),
          {}, class: "rounded bg-bg-elevated border border-white/[0.08] px-2 py-1 text-xs text-content focus-visible:ring-1 focus:outline-none" %>
      </div>
      <div>
        <%= f.select :resource_type, options_for_select([["All resources", ""]] + @available_resource_types.map { |v| [v, v] }, @filters["resource_type"]),
          {}, class: "rounded bg-bg-elevated border border-white/[0.08] px-2 py-1 text-xs text-content focus-visible:ring-1 focus:outline-none" %>
      </div>
      <%= f.submit "Apply", class: "rounded bg-accent text-content px-3 py-1 text-xs font-semibold cursor-pointer hover:bg-accent-hover transition-colors focus-visible:ring-1 focus:outline-none" %>
    <% end %>
  </div>

  <%# Log entries — dense responsive grid/list %>
  <div class="px-4 py-4">
    <% if @audit_logs.any? %>
      <div class="space-y-2">
        <% @audit_logs.each do |audit_log| %>
          <% changes = audit_log.audit_changes || audit_log.audited_changes %>
          <article class="bg-bg-card border border-white/[0.06] rounded-lg overflow-hidden">
            <%# Collapsed row summary — grid on desktop, stacked on mobile %>
            <div class="grid grid-cols-1 md:grid-cols-12 gap-x-4 gap-y-1 px-4 py-3">
              <%# Time %>
              <div class="md:col-span-2 flex items-center gap-2">
                <span class="text-xs text-content-secondary font-mono whitespace-nowrap"><%= audit_log.created_at.strftime("%Y-%m-%d %H:%M") %></span>
              </div>

              <%# Action badge %>
              <div class="md:col-span-1 flex items-center">
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold <%= audit_log_action_badge_class(audit_log.action) %>">
                  <%= audit_log.action %>
                </span>
              </div>

              <%# Actor %>
              <div class="md:col-span-2 flex items-center min-w-0">
                <span class="text-xs text-content truncate"><%= audit_log_linked_actor(audit_log) %></span>
              </div>

              <%# Resource %>
              <div class="md:col-span-2 flex items-center min-w-0">
                <span class="text-xs text-content truncate"><%= audit_log_linked_resource(audit_log, task_lookup: @audit_log_task_lookup) %></span>
              </div>

              <%# Change summary %>
              <div class="md:col-span-3 flex items-center min-w-0">
                <span class="text-xs text-content-secondary truncate"><%= audit_log_change_summary(audit_log) %></span>
              </div>

              <%# Metadata chips + IP %>
              <div class="md:col-span-2 flex items-center gap-2 min-w-0">
                <%= audit_log_metadata_chips(audit_log, limit: 2) %>
                <span class="text-[10px] text-content-muted font-mono whitespace-nowrap ml-auto"><%= audit_log.ip_address.presence || "—" %></span>
              </div>
            </div>

            <%# Detail expansion — collapsed by default %>
            <details class="border-t border-white/[0.04]">
              <summary class="flex items-center justify-between px-4 py-2 cursor-pointer text-xs text-content-muted hover:text-content-secondary transition-colors focus-visible:ring-1">
                <span class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                  </svg>
                  View details
                </span>
                <span class="text-[10px] font-mono"><%= audit_log.id %></span>
              </summary>
              <div class="px-4 pb-4 space-y-4">
                <%# Event ID + timestamp row %>
                <div class="flex flex-wrap gap-4 text-xs text-content-secondary">
                  <div>
                    <span class="text-[10px] uppercase tracking-wider text-content-muted font-semibold">Event ID</span>
                    <p class="font-mono mt-0.5"><%= audit_log.id %></p>
                  </div>
                  <div>
                    <span class="text-[10px] uppercase tracking-wider text-content-muted font-semibold">Timestamp</span>
                    <p class="font-mono mt-0.5"><%= audit_log.created_at.iso8601 %></p>
                  </div>
                  <div>
                    <span class="text-[10px] uppercase tracking-wider text-content-muted font-semibold">Actor</span>
                    <p class="mt-0.5"><%= audit_log.actor_type.presence || "—" %> <%= audit_log.actor_id.presence || "" %></p>
                  </div>
                  <div>
                    <span class="text-[10px] uppercase tracking-wider text-content-muted font-semibold">Resource</span>
                    <p class="mt-0.5"><%= audit_log.resource_type.presence || "—" %> <%= audit_log.resource_id.presence || "" %></p>
                  </div>
                </div>

                <%# IP + User Agent %>
                <div class="flex flex-wrap gap-4 text-xs text-content-secondary">
                  <div>
                    <span class="text-[10px] uppercase tracking-wider text-content-muted font-semibold">IP Address</span>
                    <p class="font-mono mt-0.5"><%= audit_log.ip_address.presence || "—" %></p>
                  </div>
                  <div class="min-w-0 flex-1">
                    <span class="text-[10px] uppercase tracking-wider text-content-muted font-semibold">User Agent</span>
                    <p class="font-mono text-[10px] mt-0.5 truncate"><%= audit_log.user_agent.presence || "—" %></p>
                  </div>
                </div>

                <%# Structured diff for changes %>
                <% if changes.present? %>
                  <div>
                    <span class="text-[10px] uppercase tracking-wider text-content-muted font-semibold block mb-2">Changes</span>
                    <% if changes.is_a?(Hash) && changes.keys.any? %>
                      <dl class="space-y-1">
                        <% changes.each do |key, values| %>
                          <div class="grid grid-cols-[80px_1fr_1fr] gap-2 text-xs font-mono items-start">
                            <dt class="text-content-muted truncate"><%= key %></dt>
                            <dd class="text-red-300 truncate" title="<%= values.is_a?(Array) ? values.first : values %>">
                              <% if values.is_a?(Array) && values.size >= 1 && values[0] %>
                                <%= audit_log_value_preview(values[0]) %>
                              <% elsif values.is_a?(Array) %>
                                —
                              <% else %>
                                <%= audit_log_value_preview(values) %>
                              <% end %>
                            </dd>
                            <dd class="text-emerald-300 truncate" title="<%= values.is_a?(Array) ? values.last : values %>">
                              <% if values.is_a?(Array) && values.size >= 2 && values[1] %>
                                <%= audit_log_value_preview(values[1]) %>
                              <% elsif values.is_a?(Array) %>
                                —
                              <% else %>
                                <%= audit_log_value_preview(values) %>
                              <% end %>
                            </dd>
                          </div>
                        <% end %>
                      </dl>
                    <% else %>
                      <p class="text-xs text-content-muted">Non-dictionary format</p>
                    <% end %>

                    <%# Raw JSON accordion %>
                    <details class="mt-2">
                      <summary class="cursor-pointer text-[10px] text-content-muted hover:text-content-secondary focus-visible:ring-1 rounded">
                        Raw JSON
                      </summary>
                      <pre class="mt-1 p-2 bg-bg-elevated rounded text-[10px] text-content-secondary font-mono overflow-x-auto"><%= JSON.pretty_generate(changes) %></pre>
                    </details>
                  </div>
                <% end %>

                <%# Metadata key/value list %>
                <% if audit_log.metadata.present? %>
                  <div>
                    <span class="text-[10px] uppercase tracking-wider text-content-muted font-semibold block mb-2">Metadata</span>
                    <dl class="space-y-1">
                      <% audit_log.metadata.each do |key, value| %>
                        <div class="flex items-start gap-2 text-xs">
                          <dt class="text-content-muted font-mono min-w-[80px] truncate"><%= key %></dt>
                          <dd class="text-content-secondary font-mono truncate flex-1"><%= audit_log_value_preview(value) %></dd>
                        </div>
                      <% end %>
                    </dl>

                    <%# Raw metadata JSON accordion %>
                    <details class="mt-2">
                      <summary class="cursor-pointer text-[10px] text-content-muted hover:text-content-secondary focus-visible:ring-1 rounded">
                        Raw JSON
                      </summary>
                      <pre class="mt-1 p-2 bg-bg-elevated rounded text-[10px] text-content-secondary font-mono overflow-x-auto"><%= JSON.pretty_generate(audit_log.metadata) %></pre>
                    </details>
                  </div>
                <% end %>
              </div>
            </details>
          </article>
        <% end %>
      </div>

      <%# Pagination %>
      <div class="flex items-center justify-between text-sm text-content-secondary mt-6">
        <div>Page <%= @page %></div>
        <div class="flex items-center gap-2">
          <% if @page > 1 %>
            <%= link_to "Previous", admin_audit_logs_path(@filters.merge(page: @page - 1)),
              class: "px-3 py-1.5 rounded-md border border-white/[0.08] hover:bg-white/[0.04] transition-colors focus-visible:ring-1 cursor-pointer" %>
          <% end %>
          <% if @has_next_page %>
            <%= link_to "Next", admin_audit_logs_path(@filters.merge(page: @page + 1)),
              class: "px-3 py-1.5 rounded-md border border-white/[0.08] hover:bg-white/[0.04] transition-colors focus-visible:ring-1 cursor-pointer" %>
          <% end %>
        </div>
      </div>
    <% else %>
      <%# Empty state %>
      <div class="bg-bg-card border border-white/[0.06] rounded-lg px-6 py-12 text-center">
        <div class="text-lg font-semibold text-content mb-2">No audit logs found</div>
        <div class="text-sm text-content-secondary mb-4">
          <% if @filters.values.any?(&:present?) %>
            Current filters returned no results.
          <% else %>
            No activity recorded yet.
          <% end %>
        </div>
        <%= link_to "Reset filters", admin_audit_logs_path,
          class: "inline-flex items-center justify-center rounded-md border border-white/[0.08] px-4 py-2 text-sm font-semibold text-content-secondary hover:text-content transition-colors focus-visible:ring-1" %>
      </div>
    <% end %>
  </div>
</section>
