<!DOCTYPE html>
<html>
  <head>
    <% marketing_protocol = ENV["APP_PROTOCOL"].presence || request.protocol.delete_suffix("://") %>
    <% marketing_host = ENV["APP_HOST"].presence || request.host_with_port %>
    <% marketing_base_url = "#{marketing_protocol}://#{marketing_host}" %>

    <title>Apex Claw - Multi-Agent Operations Workspace</title>
    <meta name="description" content="Operator workspace for managing, monitoring, and orchestrating multi-agent systems with OpenClaw.">

    <%# Open Graph / Facebook %>
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= marketing_base_url %>/">
    <meta property="og:title" content="Apex Claw - Multi-Agent Operations Workspace">
    <meta property="og:description" content="Operator workspace for managing, monitoring, and orchestrating multi-agent systems with OpenClaw.">
    <meta property="og:image" content="<%= image_url('og-image.png') %>">

    <%# Twitter %>
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="<%= marketing_base_url %>/">
    <meta property="twitter:title" content="Apex Claw - Multi-Agent Operations Workspace">
    <meta property="twitter:description" content="Operator workspace for managing, monitoring, and orchestrating multi-agent systems with OpenClaw.">
    <meta property="twitter:image" content="<%= image_url('og-image.png') %>">
    <meta name="twitter:creator" content="@andresmax">

    <%# Canonical URL %>
    <link rel="canonical" href="<%= marketing_base_url %>/">

    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Apex Claw">
    <meta name="application-name" content="Apex Claw">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#050810">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Schema.org structured data %>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Apex Claw",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Web",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "description": "Operator workspace for managing, monitoring, and orchestrating multi-agent systems with OpenClaw.",
      "url": "<%= marketing_base_url %>/"
    }
    </script>

    <%# Fonts: Clash Display (headlines) + Satoshi (body) %>
    <link href="https://api.fontshare.com/v2/css?f[]=clash-display@700,600,500&f[]=satoshi@400,500,700&display=swap" rel="stylesheet">

    <%= yield :head %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%# Favicons %>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

    <%# Tailwind CSS (compiled by tailwindcss-rails into app/assets/builds/) %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%# Application stylesheet manifest %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= render "application/plausible_analytics" %>
  </head>
  <body class="bg-bg-base min-h-screen text-content" style="font-family: 'Satoshi', sans-serif;">
    <%# Starry background effect %>
    <div class="stars"></div>
    <div class="nebula"></div>
    <%= yield %>
  </body>
</html>
