<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Apex Claw Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="Apex Claw">
    <meta name="application-name" content="Apex Claw">
    <meta name="mobile-web-app-capable" content="yes">
    <%# Theme colors for Safari and other browsers %>
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#1c1917" media="(prefers-color-scheme: dark)">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%# Fonts %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
    <%= yield :head %>
    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <%# Favicons %>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <%# Tailwind CSS (compiled by tailwindcss-rails into app/assets/builds/) %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%# Application stylesheet manifest %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body data-controller="turbo-progress" class="h-screen overflow-hidden bg-bg-base text-content font-sans">
    <% if authenticated? %>
      <%# Authenticated shell layout with sidebar %>
      <div class="flex h-screen">
        <%# Workspace sidebar (desktop) %>
        <%= render "shared/workspace_sidebar" %>

        <%# Main content area %>
        <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
          <%# Top utility bar %>
          <%= render "shared/workspace_topbar" %>

          <%# Page content %>
          <div class="flex-1 overflow-y-auto">
            <main class="container max-w-6xl mx-auto text-content-secondary font-normal text-sm px-4 pt-6">
              <%= yield %>
            </main>
          </div>
        </div>

        <%# Mobile navigation drawer %>
        <%= render "shared/mobile_workspace_nav" %>
      </div>
    <% else %>
      <%# Unauthenticated - simple layout %>
      <div class="h-screen flex flex-col bg-bg-base">
        <div class="flex-1 overflow-y-auto">
          <main class="container max-w-6xl mx-auto text-content-secondary font-normal text-sm px-4 pt-24">
            <%= yield %>
          </main>
        </div>
      </div>
    <% end %>
  </body>
</html>