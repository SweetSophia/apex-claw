<% scope_label = command_preset.agent.present? ? "Agent scoped" : "Global" %>
<% payload_preview = if command_preset.payload.present?
     command_preset.payload.map { |key, value| "#{key}: #{value.is_a?(String) ? value : value.to_json}" }.join(" · ")
   end %>

<%= tag.div id: dom_id(command_preset), class: "group mb-3 rounded-lg border border-white/[0.08] bg-bg-card p-4 cursor-pointer hover:border-white/[0.12] transition-colors" do %>
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-center gap-2">
        <h3 class="truncate text-sm font-medium text-content"><%= command_preset.name %></h3>
        <span class="rounded-full px-1.5 py-0.5 text-[10px] <%= command_preset.active? ? 'bg-[#34d399]/10 text-[#34d399]' : 'bg-white/[0.05] text-content-secondary' %>"><%= command_preset.active? ? 'Active' : 'Inactive' %></span>
        <span class="rounded-full bg-[#fbbf24]/10 px-1.5 py-0.5 text-[10px] text-[#fbbf24]"><%= command_preset.kind.humanize %></span>
        <span class="rounded-full bg-white/[0.05] px-1.5 py-0.5 text-[10px] text-content-secondary"><%= scope_label %></span>
      </div>

      <% if command_preset.description.present? %>
        <p class="mt-1 text-xs text-content-secondary"><%= command_preset.description %></p>
      <% end %>

      <div class="mt-2 text-xs text-content-muted">
        <%= command_preset.agent.present? ? "Agent: #{command_preset.agent.name}" : "Available to all agents" %>
        <% if command_preset.updated_at.present? %>
          · Updated <%= time_ago_in_words(command_preset.updated_at) %> ago
        <% end %>
      </div>

      <% if payload_preview.present? %>
        <div class="mt-2 truncate text-xs text-content-secondary" title="<%= payload_preview %>">Payload: <%= truncate(payload_preview, length: 140) %></div>
      <% end %>
    </div>

    <div class="flex items-center gap-2 opacity-100 transition-opacity md:opacity-0 md:group-hover:opacity-100">
      <%= link_to "Edit", command_preset_path(command_preset), class: "text-xs text-content-secondary transition-colors hover:text-[#fbbf24]" %>
      <%= button_to "Delete", command_preset_path(command_preset), method: :delete,
            form: { data: { turbo_confirm: "Delete this command preset?" } },
            class: "text-xs text-red-400 transition-colors hover:text-red-300 cursor-pointer" %>
    </div>
  </div>
<% end %>
