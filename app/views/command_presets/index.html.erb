<% agents = current_user.agents.active.order(:name) %>
<% active_count = @command_presets.count(&:active?) %>
<% global_count = @command_presets.count { |preset| preset.agent_id.nil? } %>

<div class="max-w-5xl mx-auto px-4 py-8">
  <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h1 class="text-xl font-semibold text-content">Command Presets</h1>
      <p class="mt-1 text-xs text-content-secondary">Reusable runtime actions for replaying safe operational commands across your fleet.</p>

      <% if @command_presets.any? %>
        <div class="mt-3 flex flex-wrap gap-2">
          <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-content-secondary"><%= pluralize(@command_presets.size, "preset") %></span>
          <span class="rounded-full bg-[#34d399]/10 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-[#34d399]"><%= active_count %> active</span>
          <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-[#fbbf24]"><%= global_count %> global</span>
        </div>
      <% end %>
    </div>
  </div>

  <div id="command_preset_form" class="mb-8 rounded-lg border border-white/[0.08] bg-bg-card p-5">
    <div class="mb-3 text-xs font-semibold uppercase tracking-wider text-content-muted">New Command Preset</div>
    <%= render "command_presets/form", command_preset: CommandPreset.new, agents: agents %>
  </div>

  <div id="command_presets_list">
    <% if @command_presets.any? %>
      <%= render partial: "command_presets/command_preset_card", collection: @command_presets, as: :command_preset %>
    <% else %>
      <div class="py-12 text-center text-content-secondary">
        <p class="text-sm">No command presets yet. Create your first runtime shortcut above.</p>
      </div>
    <% end %>
  </div>
</div>
