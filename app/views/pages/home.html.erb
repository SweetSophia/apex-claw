<div class="min-h-screen flex flex-col relative z-10">

  <div class="pt-20 pb-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <div class="mb-6">
        <%= image_tag "apex-claw-logo.svg", alt: "Apex Claw", class: "h-9 w-auto mx-auto" %>
      </div>

      <h1 class="text-3xl sm:text-4xl font-semibold text-content tracking-tight leading-tight mb-4 font-display">
        Apex Claw for<br class="hidden sm:block"> multi-agent operations
      </h1>

      <p class="text-base sm:text-lg text-content-secondary mb-8 max-w-2xl mx-auto leading-relaxed">
        Coordinate agents, reusable skills, workflows, routing rules, handoffs, and command presets from one operator workspace.
        Apex Claw turns the full control plane into a visible, operable product surface.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center items-center">
        <%= link_to new_session_path, class: "inline-flex items-center px-5 py-2.5 bg-accent text-content font-semibold rounded-md hover:bg-accent-hover transition-colors text-sm" do %>
          Open workspace
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        <% end %>

        <%= link_to "https://github.com/SweetSophia/clawdeck", target: "_blank", class: "inline-flex items-center px-5 py-2.5 bg-bg-surface text-content border border-border font-semibold rounded-md hover:bg-bg-elevated transition-colors text-sm" do %>
          <svg class="mr-2 w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
          View source
        <% end %>
      </div>
    </div>
  </div>

  <div class="px-6 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
      <div class="bg-bg-surface border border-border rounded-lg p-5">
        <div class="w-7 h-7 mb-2 text-[#fbbf24]">
          <svg viewBox="0 0 24 24" fill="none"><path d="M12 2a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2 2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z" fill="currentColor"/><path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><rect x="5" y="8" width="14" height="10" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M9 14h6M12 14v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="12" r="1" fill="currentColor"/><circle cx="15" cy="12" r="1" fill="currentColor"/></svg>
        </div>
        <h3 class="text-sm font-semibold text-content mb-1 font-display">Agent control depth</h3>
        <p class="text-xs text-content-secondary">Instructions, settings, queue visibility, archive and restore, plus live agent health.</p>
      </div>

      <div class="bg-bg-surface border border-border rounded-lg p-5">
        <div class="w-7 h-7 mb-2 text-[#fbbf24]">
          <svg viewBox="0 0 24 24" fill="none"><path d="M12 5a4 4 0 1 0 0 8 4 4 0 0 0 0-8z" stroke="currentColor" stroke-width="1.5"/><path d="M12 3v1M12 17v1M5.22 8.22l.71.71M17.07 14.07l.71.71M3 12h1M20 12h1M5.22 15.78l.71-.71M17.07 9.93l.71-.71" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M9 12a6 6 0 0 1 6 0c0 3.5-2 5-3 6H6c-1-1-3-2.5-3-6a6 6 0 0 1 6 0" stroke="currentColor" stroke-width="1.5"/></svg>
        </div>
        <h3 class="text-sm font-semibold text-content mb-1 font-display">Skills library</h3>
        <p class="text-xs text-content-secondary">Reusable knowledge blocks that can be assigned across the workspace.</p>
      </div>

      <div class="bg-bg-surface border border-border rounded-lg p-5">
        <div class="w-7 h-7 mb-2 text-[#fbbf24]">
          <svg viewBox="0 0 24 24" fill="none"><path d="M13 3L4 14h7l-2 7 9-11h-7l2-7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="text-sm font-semibold text-content mb-1 font-display">Autoworkflows</h3>
        <p class="text-xs text-content-secondary">Manual and triggered workflows with execution history and failure visibility.</p>
      </div>

      <div class="bg-bg-surface border border-border rounded-lg p-5">
        <div class="w-7 h-7 mb-2 text-[#fbbf24]">
          <svg viewBox="0 0 24 24" fill="none"><path d="M17 1l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 11V9a4 4 0 0 1 4-4h14M7 23l-4-4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 13v2a4 4 0 0 1-4 4H3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="text-sm font-semibold text-content mb-1 font-display">Handoff automation</h3>
        <p class="text-xs text-content-secondary">Templates, escalation logic, and clearer agent-to-agent transfer paths.</p>
      </div>

      <div class="bg-bg-surface border border-border rounded-lg p-5">
        <div class="w-7 h-7 mb-2 text-[#fbbf24]">
          <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 3v9l4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="text-sm font-semibold text-content mb-1 font-display">Routing rules</h3>
        <p class="text-xs text-content-secondary">Skill, tag, priority, and status-aware routing for explainable automation.</p>
      </div>

      <div class="bg-bg-surface border border-border rounded-lg p-5">
        <div class="w-7 h-7 mb-2 text-[#fbbf24]">
          <svg viewBox="0 0 24 24" fill="none"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="text-sm font-semibold text-content mb-1 font-display">Command presets</h3>
        <p class="text-xs text-content-secondary">Reusable operational commands that stay explicit and auditable.</p>
      </div>
    </div>
  </div>

  <footer class="pt-6 pb-12 flex flex-wrap items-center justify-center gap-x-1 gap-y-2 text-xs text-content-muted">
    <span>Apex Claw operator workspace for multi-agent operations.</span>
    <span>·</span>
    <a href="https://github.com/SweetSophia/clawdeck" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-accent hover:text-accent-hover transition-colors">
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
      GitHub
    </a>
  </footer>

</div>
