<% content_for :title, "Settings" %>
<% content_for :breadcrumb_standalone, "Settings" %>

<div class="space-y-6 mt-12">
  <!-- Section 1: Profile -->
  <div class="bg-bg-surface border border-border rounded-lg p-5 space-y-4">
    <h3 class="text-xs font-medium text-content-muted uppercase tracking-wider font-display">Profile</h3>

    <%= form_with(model: @user, url: settings_path, method: :patch, class: "space-y-4") do |form| %>
      <!-- Avatar -->
      <div>
        <label class="block text-xs font-medium text-content-secondary mb-2">Avatar</label>
        <div class="flex items-center gap-4">
          <% if @user.has_avatar? %>
            <%= image_tag @user.avatar_source, class: "w-14 h-14 object-cover rounded-full" %>
          <% else %>
            <div class="w-14 h-14 rounded-full bg-bg-elevated flex items-center justify-center">
              <svg class="w-7 h-7 text-content-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
          <% end %>
          <div class="flex-1">
            <%= form.file_field :avatar, accept: "image/jpeg,image/jpg,image/png,image/webp", class: "block w-full text-xs text-content-secondary file:mr-3 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-medium file:bg-bg-elevated file:text-content-secondary hover:file:bg-bg-hover file:cursor-pointer file:transition-colors" %>
            <p class="text-xs text-content-muted mt-1">Max 512KB, 256x256px. JPEG, PNG, or WebP.</p>
          </div>
        </div>
        <% if @user.avatar.attached? || @user.avatar_url.present? %>
          <div class="mt-3">
            <label class="flex items-center text-xs text-content-secondary cursor-pointer">
              <%= form.check_box :remove_avatar, class: "mr-2 rounded border-border bg-bg-elevated text-accent focus:ring-accent focus:ring-offset-bg-surface" %>
              Remove avatar
            </label>
          </div>
        <% end %>
        <% if @user.errors[:avatar].any? %>
          <div class="mt-2">
            <% @user.errors[:avatar].each do |error| %>
              <p class="text-status-error text-xs">Avatar <%= error %></p>
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- Email -->
      <div class="pt-4 border-t border-border">
        <label class="block text-xs font-medium text-content-secondary mb-1.5">Email Address</label>
        <%= form.email_field :email_address, placeholder: "your@email.com", class: "block w-full bg-bg-elevated border-0 rounded-md px-3 py-2 text-sm text-content placeholder:text-content-muted focus:ring-1 focus:ring-accent focus:outline-none" %>
        <% if @user.errors[:email_address].any? %>
          <div class="mt-1">
            <% @user.errors[:email_address].each do |error| %>
              <p class="text-status-error text-xs">Email <%= error %></p>
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- Theme Preference -->
      <div class="pt-4 border-t border-border">
        <label class="block text-xs font-medium text-content-secondary mb-1.5">Theme</label>
        <div class="flex items-center gap-3">
          <label class="flex items-center gap-2 cursor-pointer">
            <%= form.radio_button :theme_preference, "dark", class: "sr-only peer" %>
            <span class="px-3 py-1.5 text-xs font-medium rounded-md border transition-colors peer-checked:bg-accent peer-checked:text-content peer-checked:border-accent text-content-secondary border-border">
              <span class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-[#60a5fa]">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0118 15.75 9.75 9.75 0 018.25 6c0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25 9.75 9.75 0 0012.75 21a9.753 9.753 0 009.002-5.998Z" />
                </svg>
                Dark
              </span>
            </span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <%= form.radio_button :theme_preference, "light", class: "sr-only peer" %>
            <span class="px-3 py-1.5 text-xs font-medium rounded-md border transition-colors peer-checked:bg-accent peer-checked:text-content peer-checked:border-accent text-content-secondary border-border">
              <span class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-[#fbbf24]">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
                </svg>
                Light
              </span>
            </span>
          </label>
        </div>
        <p class="text-xs text-content-muted mt-1.5">Quickly toggle between dark and light mode using the button in the top bar.</p>
      </div>

      <div class="pt-2">
        <%= form.submit "Save profile", class: "cursor-pointer px-4 py-2 bg-accent text-content hover:bg-accent-hover text-xs font-semibold rounded-md transition-colors duration-200" %>
      </div>
    <% end %>
  </div>

  <!-- Section 2: Multi-agent Integration -->
  <div id="agents" class="bg-bg-surface border border-border rounded-lg p-5 space-y-5">
    <div class="flex items-center justify-between gap-3 flex-wrap">
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-accent">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
        </svg>
        <div>
          <h3 class="text-sm font-semibold text-content font-display">Agent Registration</h3>
          <p class="text-xs text-content-secondary mt-1">Use join tokens for real agent registration. Header-only presence does not create an agent record.</p>
        </div>
      </div>
      <%= button_to "Generate join token", generate_join_token_settings_path,
          method: :post,
          class: "cursor-pointer px-3 py-1.5 bg-accent text-content hover:bg-accent-hover text-xs font-semibold rounded-md transition-colors" %>
    </div>

    <% api_url = "#{request.base_url}/api/v1" %>
    <% api_token = flash[:api_token_plaintext].presence || "•••••••• (regenerate to see token)" %>
    <% join_token = flash[:join_token_plaintext] %>
    <% join_token_expires_at = flash[:join_token_expires_at] %>

    <% integration_prompt = agent_registration_prompt(api_url: api_url, api_token: api_token, join_token: join_token) %>

    <% if join_token.present? %>
      <% expires_at = join_token_expires_at.present? ? Time.zone.parse(join_token_expires_at) : nil %>
      <div data-controller="clipboard" class="space-y-3 rounded-lg border border-amber-500/30 bg-amber-500/10 p-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-amber-300">Join token</p>
          <p class="mt-1 text-xs text-content-secondary">Copy and share this raw token only for agent registration. Do not paraphrase or shorten it.</p>
        </div>
        <div class="rounded-md bg-bg-elevated px-3 py-3">
          <code data-clipboard-target="source" class="block break-all font-mono text-xs text-content"><%= join_token %></code>
        </div>
        <div class="flex items-center gap-3 flex-wrap">
          <button type="button"
                  data-action="click->clipboard#copy"
                  class="cursor-pointer px-3 py-1.5 bg-amber-500/20 hover:bg-amber-500/30 text-amber-200 text-xs font-medium rounded-md transition-colors">
            <span data-clipboard-target="label">Copy join token only</span>
          </button>
          <span class="text-xs text-amber-300">Single use.<% if expires_at %> Expires in <%= distance_of_time_in_words(Time.current, expires_at) %>.<% end %></span>
        </div>
      </div>
    <% end %>

    <div data-controller="clipboard" class="space-y-3">
      <div class="bg-bg-elevated rounded-md max-h-96 overflow-y-auto">
        <pre data-clipboard-target="source" class="px-3 py-3 text-xs font-mono text-content-secondary whitespace-pre-wrap break-words leading-relaxed"><%= integration_prompt %></pre>
      </div>
      <div class="flex items-center gap-3 flex-wrap">
        <button type="button"
                data-action="click->clipboard#copy"
                class="cursor-pointer px-3 py-1.5 bg-bg-elevated hover:bg-bg-hover text-content-secondary text-xs font-medium rounded-md transition-colors">
          <span data-clipboard-target="label">Copy registration prompt</span>
        </button>
        <%= button_to "Regenerate user API token", regenerate_api_token_settings_path,
            method: :post,
            data: { turbo_confirm: "This will invalidate your current user API token. Continue?" },
            class: "cursor-pointer text-xs text-content-muted hover:text-content-secondary transition-colors" %>
      </div>
    </div>

    <div class="pt-4 border-t border-border space-y-3">
      <div class="flex items-center justify-between gap-3 flex-wrap">
        <div>
          <p class="text-xs font-medium text-content-secondary">Registered agents</p>
          <p class="text-xs text-content-muted mt-1">These are real agent records. Multi-agent assignment, heartbeats, and health cards use this list.</p>
        </div>
        <%= link_to agents_path, class: "text-xs text-accent hover:text-accent-hover transition-colors" do %>
          Open agents tab
        <% end %>
      </div>

      <% if @registered_agents.any? %>
        <div class="space-y-2">
          <% @registered_agents.each do |agent| %>
            <div class="flex items-center justify-between gap-3 rounded-lg border border-border bg-bg-elevated px-3 py-2">
              <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-content-muted">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
                  </svg>
                  <span class="text-sm font-semibold text-content"><%= agent.name %></span>
                  <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded <%= agent.online? ? 'bg-emerald-500/20 text-emerald-400' : agent.draining? ? 'bg-yellow-500/20 text-yellow-400' : 'bg-white/[0.06] text-content-muted' %>"><%= agent.status.humanize %></span>
                </div>
                <div class="text-xs text-content-muted mt-1">
                  <%= agent.hostname.presence || 'unknown host' %>
                  <% if agent.last_heartbeat_at.present? %>
                    • heartbeat <%= time_ago_in_words(agent.last_heartbeat_at) %> ago
                  <% end %>
                </div>
              </div>
              <div class="text-right text-xs text-content-muted">
                <div><%= agent.assigned_tasks.where.not(status: :done).count %> assigned</div>
                <div><%= agent.claimed_tasks.where.not(status: :done).count %> claimed</div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-xs text-content-muted">No registered agents yet. Generate a join token and register each agent once.</p>
      <% end %>
    </div>
  </div>
</div>
