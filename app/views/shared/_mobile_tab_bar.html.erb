<%# Mobile bottom tab bar - 5 tabs: Home, Boards, Agents, Workflows, More %>
<% active_path = request.path %>

<nav class="fixed bottom-0 left-0 right-0 z-[100] lg:hidden bg-bg-surface border-t border-white/[0.05] safe-area-bottom" aria-label="Mobile navigation">
  <div class="flex items-center justify-around h-16 px-2">
    <%# Home %>
    <%= link_to home_path,
        class: "flex flex-col items-center justify-center gap-1 px-3 py-2 rounded-lg transition-colors #{nav_item_active?({href: home_path}, active_path) ? 'text-content' : 'text-content-muted hover:text-content-secondary'}",
        aria_current: nav_item_active?({href: home_path}, active_path) ? "page" : nil do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
      </svg>
      <span class="text-[10px] font-medium">Home</span>
    <% end %>

    <%# Boards %>
    <%= link_to boards_path,
        class: "flex flex-col items-center justify-center gap-1 px-3 py-2 rounded-lg transition-colors #{nav_item_active?({href: boards_path}, active_path) ? 'text-content' : 'text-content-muted hover:text-content-secondary'}",
        aria_current: nav_item_active?({href: boards_path}, active_path) ? "page" : nil do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
      </svg>
      <span class="text-[10px] font-medium">Boards</span>
    <% end %>

    <%# Agents %>
    <%= link_to agents_path,
        class: "flex flex-col items-center justify-center gap-1 px-3 py-2 rounded-lg transition-colors #{nav_item_active?({href: agents_path}, active_path) ? 'text-content' : 'text-content-muted hover:text-content-secondary'}",
        aria_current: nav_item_active?({href: agents_path}, active_path) ? "page" : nil do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 3A2.25 2.25 0 006.75 5.25v14.25a2.25 2.25 0 002.25 2.25h6.75a2.25 2.25 0 002.25-2.25V5.25A2.25 2.25 0 0015.75 3h-7.5zM19.5 12h.008v.008H19.5V12zm-.375 0h.008v.008H19.125V12z" />
      </svg>
      <span class="text-[10px] font-medium">Agents</span>
    <% end %>

    <%# Workflows %>
    <%= link_to workflows_path,
        class: "flex flex-col items-center justify-center gap-1 px-3 py-2 rounded-lg transition-colors #{nav_item_active?({href: workflows_path}, active_path) ? 'text-content' : 'text-content-muted hover:text-content-secondary'}",
        aria_current: nav_item_active?({href: workflows_path}, active_path) ? "page" : nil do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
      </svg>
      <span class="text-[10px] font-medium">Workflows</span>
    <% end %>

    <%# More - opens mobile drawer %>
    <button type="button"
            data-controller="ui-event"
            data-ui-event-name-value="workspace-nav:open"
            data-action="click->ui-event#dispatch"
            class="flex flex-col items-center justify-center gap-1 px-3 py-2 rounded-lg transition-colors text-content-muted hover:text-content-secondary focus:outline-none focus-visible:ring-2 focus-visible:ring-[#fbbf24]/50">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <span class="text-[10px] font-medium">More</span>
    </button>
  </div>
</nav>
