<%# Workspace sidebar - persistent left nav for desktop (lg+), 272px wide %>
<% active_path = request.path %>
<% sidebar_boards = authenticated? ? (defined?(@boards) && @boards ? @boards : current_user.boards) : [] %>
<% sidebar_current_board = @board || sidebar_boards.first %>

<aside class="hidden lg:flex lg:flex-col lg:h-screen lg:w-[272px] lg:border-r lg:border-white/[0.05] bg-bg-surface fixed inset-y-0 left-0 z-[110]">
  <%# Header: workspace name + board switcher %>
  <div class="flex-shrink-0 px-3 pt-3 pb-2">
    <%# Workspace wordmark %>
    <div class="px-2 py-2 mb-2">
      <span class="text-sm font-bold text-content tracking-[-0.02em]">Apex Claw</span>
    </div>

    <%# Board switcher trigger %>
    <% if authenticated? && sidebar_current_board %>
      <div class="relative" data-controller="dropdown">
        <button type="button"
                data-dropdown-target="button"
                data-action="click->dropdown#toggle"
                class="flex items-center gap-2 w-full cursor-pointer hover:bg-white/[0.04] px-2 py-2 rounded-lg transition-colors border border-transparent hover:border-white/[0.06] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#fbbf24]/50"
                aria-label="Board switcher">
          <span class="text-base"><%= sidebar_current_board.icon %></span>
          <span class="flex-1 min-w-0 text-left">
            <span class="block text-sm font-semibold text-content truncate"><%= sidebar_current_board.name %></span>
          </span>
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" class="opacity-40 transition-transform" data-dropdown-target="chevron">
            <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <%# Board switcher dropdown menu %>
        <div data-dropdown-target="menu"
             class="hidden absolute left-0 top-full mt-1.5 w-[220px] p-1.5 rounded-xl border border-white/[0.08] z-50 animate-drop-in shadow-[0_20px_50px_rgba(0,0,0,0.6)] bg-bg-dropdown">
          <%# Board list %>
          <div class="max-h-[50vh] overflow-y-auto">
            <% sidebar_boards.each do |board| %>
              <% board_color = board_hex_color(board) %>
              <% is_active = @board && @board.id == board.id %>
              <%= link_to board_path(board),
                  class: "flex items-center gap-2.5 w-full px-2.5 py-[9px] rounded-lg transition-colors #{is_active ? 'bg-white/[0.06]' : 'hover:bg-white/[0.04]'}",
                  data: { turbo_frame: "_top" } do %>
                <span class="text-sm w-6 text-center"><%= board.icon %></span>
                <span class="text-[13px] font-semibold flex-1 truncate #{is_active ? 'text-content' : 'text-content-secondary'}"><%= board.name %></span>
                <% if is_active %>
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8.5L6.5 12L13 4" stroke="<%= board_color %>" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                <% end %>
              <% end %>
            <% end %>
          </div>
          <%# Divider %>
          <div class="h-px bg-white/[0.06] my-1"></div>
          <%# Create new board %>
          <button type="button"
                  onclick="document.getElementById('new-board-modal').classList.remove('hidden')"
                  class="flex items-center gap-2.5 w-full px-2.5 py-[9px] rounded-lg hover:bg-white/[0.04] transition-colors cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-[#fbbf24]/50">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="ml-1">
              <path d="M8 3V13M3 8H13" stroke="#555" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span class="text-[13px] font-medium text-content-muted">Create new board</span>
          </button>
        </div>
      </div>
    <% elsif authenticated? %>
      <%= link_to boards_path, class: "flex items-center gap-2 px-2 py-2 rounded-lg hover:bg-white/[0.04] transition-colors" do %>
        <span class="text-sm font-semibold text-content">All Boards</span>
      <% end %>
    <% end %>
  </div>

  <%# Scrollable nav sections %>
  <nav class="flex-1 overflow-y-auto px-3 py-2 space-y-6">
    <%# Workspace section %>
    <div>
      <div class="px-2 py-1.5">
        <span class="text-[10px] font-semibold uppercase tracking-[0.08em] text-content-ghost">Workspace</span>
      </div>
      <div class="space-y-0.5">
        <%= render "shared/nav_item", title: "Home", href: home_path, is_active: nav_item_active?({href: home_path}, active_path), svg_path: '<path d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" stroke-linecap="round" stroke-linejoin="round"/>' %>
        <%= render "shared/nav_item", title: "Boards", href: boards_path, is_active: nav_item_active?({href: boards_path}, active_path), svg_path: '<path d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" stroke-linecap="round" stroke-linejoin="round"/>' %>
      </div>
    </div>

    <%# Operations section %>
    <div>
      <div class="px-2 py-1.5">
        <span class="text-[10px] font-semibold uppercase tracking-[0.08em] text-content-ghost">Operations</span>
      </div>
      <div class="space-y-0.5">
        <%= render "shared/nav_item", title: "Agents", href: agents_path, is_active: nav_item_active?({href: agents_path}, active_path), svg_path: '<path d="M8.25 3v1.5M4.5 3A2.25 2.25 0 006.75 5.25v14.25a2.25 2.25 0 002.25 2.25h6.75a2.25 2.25 0 002.25-2.25V5.25A2.25 2.25 0 0015.75 3h-7.5zM19.5 12h.008v.008H19.5V12zm-.375 0h.008v.008H19.125V12z" stroke-linecap="round" stroke-linejoin="round"/>' %>
        <%= render "shared/nav_item", title: "Skills", href: skills_path, is_active: nav_item_active?({href: skills_path}, active_path), svg_path: '<path d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z" stroke-linecap="round" stroke-linejoin="round"/>' %>
        <%= render "shared/nav_item", title: "Workflows", href: workflows_path, is_active: nav_item_active?({href: workflows_path}, active_path), svg_path: '<path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" stroke-linecap="round" stroke-linejoin="round"/>' %>
        <%= render "shared/nav_item", title: "Handoffs", href: handoff_templates_path, is_active: nav_item_active?({href: handoff_templates_path}, active_path), svg_path: '<path d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" stroke-linecap="round" stroke-linejoin="round"/>' %>
        <%= render "shared/nav_item", title: "Routing", href: routing_rules_path, is_active: nav_item_active?({href: routing_rules_path}, active_path), svg_path: '<path d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z" stroke-linecap="round" stroke-linejoin="round"/>' %>
        <%= render "shared/nav_item", title: "Presets", href: command_presets_path, is_active: nav_item_active?({href: command_presets_path}, active_path), svg_path: '<path d="M6.75 7.5l3 2.25-3 2.25m4.5 0H21m-9.5-6h4.5a2.25 2.25 0 012.25 2.25v6.75a2.25 2.25 0 01-2.25 2.25h-6.75a2.25 2.25 0 01-2.25-2.25V9.75A2.25 2.25 0 016.75 7.5z" stroke-linecap="round" stroke-linejoin="round"/>' %>
      </div>
    </div>

    <%# System section %>
    <div>
      <div class="px-2 py-1.5">
        <span class="text-[10px] font-semibold uppercase tracking-[0.08em] text-content-ghost">System</span>
      </div>
      <div class="space-y-0.5">
        <%= render "shared/nav_item", title: "Settings", href: settings_path, is_active: nav_item_active?({href: settings_path}, active_path), svg_path: '<path d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/>' %>
        <% if authenticated? && current_user.admin? %>
          <%= render "shared/nav_item", title: "Audit Logs", href: admin_audit_logs_path, is_active: nav_item_active?({href: admin_audit_logs_path}, active_path), svg_path: '<path d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" stroke-linecap="round" stroke-linejoin="round"/>' %>
        <% end %>
      </div>
    </div>
  </nav>

  <%# User section at bottom %>
  <% if authenticated? %>
    <div class="flex-shrink-0 px-3 py-3 border-t border-white/[0.05]">
      <%= link_to settings_path, class: "flex items-center gap-3 px-2 py-2 rounded-lg hover:bg-white/[0.04] transition-colors cursor-pointer" do %>
        <div class="w-8 h-8 rounded-lg bg-white/[0.06] flex items-center justify-center text-sm font-bold text-content overflow-hidden">
          <% if current_user.has_avatar? %>
            <%= image_tag current_user.avatar_source, class: "w-full h-full object-cover", alt: "" %>
          <% else %>
            <%= current_user.email_address.first.upcase %>
          <% end %>
        </div>
        <span class="flex-1 min-w-0">
          <span class="block text-sm font-medium text-content truncate"><%= current_user.email_address.split('@').first %></span>
        </span>
      <% end %>
    </div>
  <% end %>
</aside>