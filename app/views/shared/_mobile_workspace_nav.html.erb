<%# Mobile workspace navigation - slide-over drawer %>
<% active_path = request.path %>
<% mobile_boards = authenticated? ? (defined?(@boards) && @boards ? @boards : current_user.boards) : [] %>
<% mobile_current_board = @board || mobile_boards.first %>

<div data-controller="workspace-nav">
  <%# Backdrop overlay %>
  <button type="button"
          data-workspace-nav-target="overlay"
          class="hidden fixed inset-0 bg-black/60 z-[120] cursor-default"
          data-action="click->workspace-nav#close"
          aria-label="Close navigation overlay"></button>

  <%# Slide-in drawer %>
  <div data-workspace-nav-target="drawer"
       role="dialog"
       aria-modal="true"
       aria-labelledby="mobile-drawer-title"
       class="fixed inset-y-0 left-0 w-[280px] bg-bg-surface z-[121] shadow-[0_20px_60px_rgba(0,0,0,0.5)] -translate-x-full transition-transform duration-200">

    <%# Drawer header %>
    <div class="flex items-center justify-between px-4 h-[52px] border-b border-white/[0.05]">
      <span id="mobile-drawer-title" class="text-sm font-bold text-content tracking-[-0.02em]">Navigation</span>
      <button type="button"
              data-action="workspace-nav#close"
              class="p-2 -mr-2 rounded-lg hover:bg-white/[0.04] transition-colors cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-[#fbbf24]/50"
              aria-label="Close navigation">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-content-secondary">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <%# Board switcher in mobile drawer %>
    <% if authenticated? && mobile_current_board %>
      <div class="px-3 py-3 border-b border-white/[0.05]">
        <div class="relative" data-controller="dropdown">
          <button type="button"
                  data-dropdown-target="button"
                  data-action="click->dropdown#toggle"
                  class="flex items-center gap-2 w-full cursor-pointer hover:bg-white/[0.04] px-2 py-2 rounded-lg transition-colors border border-white/[0.06] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#fbbf24]/50"
                  aria-label="Board switcher">
            <span class="text-base"><%= mobile_current_board.icon %></span>
            <span class="flex-1 min-w-0 text-left">
              <span class="block text-sm font-semibold text-content truncate"><%= mobile_current_board.name %></span>
            </span>
            <svg width="12" height="12" viewBox="0 0 16 16" fill="none" class="opacity-40 transition-transform" data-dropdown-target="chevron">
              <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <%# Board list dropdown %>
          <div data-dropdown-target="menu"
               class="hidden absolute left-0 top-full mt-1.5 w-[220px] p-1.5 rounded-xl border border-white/[0.08] z-50 animate-drop-in shadow-[0_20px_50px_rgba(0,0,0,0.6)] bg-bg-dropdown">
            <% mobile_boards.each do |board| %>
              <% board_color = board_hex_color(board) %>
              <% is_active = @board && @board.id == board.id %>
              <%= link_to board_path(board),
                  class: "flex items-center gap-2.5 w-full px-2.5 py-[9px] rounded-lg transition-colors #{is_active ? 'bg-white/[0.06]' : 'hover:bg-white/[0.04]'}",
                  data: { turbo_frame: "_top" } do %>
                <span class="text-sm w-6 text-center"><%= board.icon %></span>
                <span class="text-[13px] font-semibold flex-1 truncate #{is_active ? 'text-content' : 'text-content-secondary'}"><%= board.name %></span>
                <% if is_active %>
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8.5L6.5 12L13 4" stroke="<%= board_color %>" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                <% end %>
              <% end %>
            <% end %>
            <%# Divider %>
            <div class="h-px bg-white/[0.06] my-1"></div>
            <%# Create new board %>
            <button type="button"
                    data-controller="modal"
                    data-action="click->modal#show"
                    data-modal-id-param="new-board-modal"
                    class="flex items-center gap-2.5 w-full px-2.5 py-[9px] rounded-lg hover:bg-white/[0.04] transition-colors cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-[#fbbf24]/50">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="ml-1">
                <path d="M8 3V13M3 8H13" stroke="#555" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <span class="text-[13px] font-medium text-content-muted">Create new board</span>
            </button>
          </div>
        </div>
      </div>
    <% end %>

    <%# Scrollable nav sections %>
    <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-6">
      <%# Workspace section %>
      <div>
        <div class="px-2 py-1.5">
          <span class="text-[10px] font-semibold uppercase tracking-[0.08em] text-content-ghost">Workspace</span>
        </div>
        <div class="space-y-0.5">
          <%= render "shared/nav_item", title: "Home", href: home_path, is_active: nav_item_active?({href: home_path}, active_path), icon: nav_icon(:home) %>
          <%= render "shared/nav_item", title: "Boards", href: boards_path, is_active: nav_item_active?({href: boards_path}, active_path), icon: nav_icon(:boards) %>
        </div>
      </div>

      <%# Operations section %>
      <div>
        <div class="px-2 py-1.5">
          <span class="text-[10px] font-semibold uppercase tracking-[0.08em] text-content-ghost">Operations</span>
        </div>
        <div class="space-y-0.5">
          <%= render "shared/nav_item", title: "Agents", href: agents_path, is_active: nav_item_active?({href: agents_path}, active_path), icon: nav_icon(:agents) %>
          <%= render "shared/nav_item", title: "Skills", href: skills_path, is_active: nav_item_active?({href: skills_path}, active_path), icon: nav_icon(:skills) %>
          <%= render "shared/nav_item", title: "Workflows", href: workflows_path, is_active: nav_item_active?({href: workflows_path}, active_path), icon: nav_icon(:workflows) %>
          <%= render "shared/nav_item", title: "Handoffs", href: handoff_templates_path, is_active: nav_item_active?({href: handoff_templates_path}, active_path), icon: nav_icon(:handoffs) %>
          <%= render "shared/nav_item", title: "Routing", href: routing_rules_path, is_active: nav_item_active?({href: routing_rules_path}, active_path), icon: nav_icon(:routing) %>
          <%= render "shared/nav_item", title: "Presets", href: command_presets_path, is_active: nav_item_active?({href: command_presets_path}, active_path), icon: nav_icon(:presets) %>
        </div>
      </div>

      <%# System section %>
      <div>
        <div class="px-2 py-1.5">
          <span class="text-[10px] font-semibold uppercase tracking-[0.08em] text-content-ghost">System</span>
        </div>
        <div class="space-y-0.5">
          <%= render "shared/nav_item", title: "Settings", href: settings_path, is_active: nav_item_active?({href: settings_path}, active_path), icon: nav_icon(:settings) %>
          <% if authenticated? && current_user.admin? %>
            <%= render "shared/nav_item", title: "Audit Logs", href: admin_audit_logs_path, is_active: nav_item_active?({href: admin_audit_logs_path}, active_path), icon: nav_icon(:audit) %>
          <% end %>
        </div>
      </div>
    </nav>

    <%# User section at bottom %>
    <% if authenticated? %>
      <div class="flex-shrink-0 px-3 py-3 border-t border-white/[0.05]">
        <div class="flex items-center gap-3 px-2 py-2">
          <div class="w-8 h-8 rounded-lg bg-white/[0.06] flex items-center justify-center text-sm font-bold text-content overflow-hidden">
            <% if current_user.has_avatar? %>
              <%= image_tag current_user.avatar_source, class: "w-full h-full object-cover", alt: "" %>
            <% else %>
              <%= current_user.email_address.first.upcase %>
            <% end %>
          </div>
          <span class="flex-1 min-w-0">
            <span class="block text-sm font-medium text-content truncate"><%= current_user.email_address.split('@').first %></span>
          </span>
        </div>
        <%= link_to "Log out", session_path,
            data: { turbo_method: :delete },
            class: "flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-[13px] font-medium text-status-error hover:bg-status-error/10 transition-colors cursor-pointer mt-1" %>
      </div>
    <% end %>
  </div>
</div>