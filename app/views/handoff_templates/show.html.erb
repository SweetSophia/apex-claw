<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <%= link_to "← Handoff Templates", handoff_templates_path, class: "text-xs text-[#888] hover:text-amber-400 transition-colors" %>
      <h1 class="text-lg font-semibold text-[#e0e0e0] mt-2"><%= @template.name %></h1>
      <p class="text-xs text-[#666] mt-1"><%= truncate(@template.context_template.to_s, length: 160) %></p>
    </div>
  </div>

  <div id="template_form" class="p-5 rounded-lg bg-[#1e1e22] border border-white/[0.08]">
    <div class="text-xs font-semibold text-[#555] uppercase tracking-wider mb-3">Edit Template</div>
    <%= render "handoff_templates/form", template: @template %>
  </div>
</div>
