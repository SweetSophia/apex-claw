<%= form_with(
      model: template,
      url: template.new_record? ? handoff_templates_path : handoff_template_path(template),
      method: template.new_record? ? :post : :patch,
      data: { turbo_submit: true, turbo_method: template.new_record? ? :post : :patch }
    ) do |f| %>
  <div class="space-y-4">
    <div>
      <label class="block text-xs font-medium text-[#888] mb-1.5">Name</label>
      <%= f.text_field :name,
            placeholder: "e.g. Backend implementation, QA follow-up",
            class: "w-full max-w-md rounded-md border border-white/[0.08] bg-white/[0.03] px-3 py-2 text-sm text-[#e0e0e0] placeholder:text-[#555] focus:outline-none focus:ring-1 focus:ring-amber-400/50" %>
    </div>

    <div>
      <label class="block text-xs font-medium text-[#888] mb-1.5">Context Template</label>
      <%= f.text_area :context_template,
            rows: 4,
            placeholder: "Summarize the work, current status, and what the next agent should know...",
            class: "w-full rounded-md border border-white/[0.08] bg-white/[0.03] px-3 py-2 text-sm text-[#e0e0e0] font-mono placeholder:text-[#555] focus:outline-none focus:ring-1 focus:ring-amber-400/50 resize-y" %>
      <p class="text-xs text-[#555] mt-1.5">Use {{task_name}}, {{task_description}}, {{task_priority}}, {{task_status}}, {{task_tags}}, {{from_agent}} as placeholders</p>
    </div>

    <div>
      <label class="block text-xs font-medium text-[#888] mb-1.5">Default Agent</label>
      <%= f.select :agent_id,
            current_user.agents.active.map { |agent| [agent.name, agent.id] },
            { prompt: "No default agent" },
            class: "w-full max-w-xs rounded-md border border-white/[0.08] bg-white/[0.03] px-3 py-2 text-sm text-[#e0e0e0] focus:outline-none focus:ring-1 focus:ring-amber-400/50" %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :auto_suggest, class: "rounded border-white/[0.08] bg-white/[0.03] text-amber-400 focus:ring-amber-400/50" %>
      <label class="text-xs text-[#888]">Auto-suggest this template during handoffs</label>
    </div>

    <div class="flex items-center justify-between">
      <span></span>
      <%= f.submit template.new_record? ? "Create Template" : "Save Changes",
            class: "px-3 py-1.5 text-xs font-medium rounded-md bg-amber-400 text-[#161619] hover:bg-amber-500 transition-colors cursor-pointer" %>
    </div>
  </div>
<% end %>
