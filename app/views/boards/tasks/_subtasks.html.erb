<%# Subtask list partial — used by Turbo Stream responses from SubtasksController %>
<% subtasks = task.subtasks.reload %>
<% board_color_hex = board_hex_color(board) %>
<% done_count = subtasks.count(&:done?) %>
<% total_count = subtasks.size %>
<% progress = total_count > 0 ? (done_count.to_f / total_count * 100).round : 0 %>

<div id="task_<%= task.id %>_subtasks" class="flex flex-col gap-0.5">
  <% subtasks.each do |subtask| %>
    <%= button_to board_task_subtask_path(board, task, subtask),
        method: :patch,
        params: { subtask: { done: !subtask.done? } },
        class: "flex items-center gap-2.5 px-2.5 py-2 rounded-lg bg-white/[0.03] border border-white/[0.04] cursor-pointer" do %>
      <% if subtask.done? %>
        <div class="w-4 h-4 rounded border-0 bg-[<%= board_color_hex %>] flex items-center justify-center flex-shrink-0">
          <svg width="9" height="9" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
      <% else %>
        <div class="w-4 h-4 rounded border border-white/20 bg-transparent flex-shrink-0"></div>
      <% end %>
      <span class="text-[12.5px] font-medium <%= subtask.done? ? 'text-[#444] line-through' : 'text-content-secondary' %>"><%= subtask.title %></span>
    <% end %>
  <% end %>
</div>
