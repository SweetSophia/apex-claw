<%# Task edit slide-in panel for kanban board %>
<%
  status_labels = {
    "inbox" => "Inbox",
    "up_next" => "Up Next",
    "in_progress" => "In Progress",
    "in_review" => "In Review",
    "done" => "Done"
  }
  status_dot_colors = {
    "inbox" => "#666",
    "up_next" => "#60a5fa",
    "in_progress" => "#fbbf24",
    "in_review" => "#a78bfa",
    "done" => "#34d399"
  }
  priority_levels = [
    { id: "none", dots: 1, color: "#555" },
    { id: "low", dots: 2, color: "#60a5fa" },
    { id: "medium", dots: 3, color: "#fbbf24" },
    { id: "high", dots: 4, color: "#ef4444" },
  ]
  board_color_hex = board_hex_color(@board)
%>

<div data-controller="task-modal"
     data-task-modal-task-id-value="<%= task.id %>"
     data-task-modal-update-url-value="<%= board_task_path(@board, task) %>"
     data-task-modal-assign-url-value="<%= assign_board_task_path(@board, task) %>"
     data-task-modal-unassign-url-value="<%= unassign_board_task_path(@board, task) %>">
  <!-- Backdrop -->
  <div data-task-modal-target="backdrop"
       data-action="click->task-modal#close"
       class="hidden opacity-0 transition-opacity duration-200 ease-out fixed inset-0 bg-black/40 z-[200]">
  </div>
  <!-- Slide-in Panel -->
  <div data-task-modal-target="modal"
       class="hidden translate-x-full transition-transform duration-200 ease-out fixed top-0 right-0 w-full sm:w-[400px] h-screen bg-bg-elevated border-l border-white/[0.06] flex flex-col z-[201] overflow-hidden slideIn">

    <!-- Header — status pill + close -->
    <div class="p-4 px-5 border-b border-white/[0.05] flex items-center justify-between">
      <div data-task-modal-target="statusPill" class="text-[11px] font-bold text-[#ccc] bg-white/[0.06] px-3 py-1 rounded-md border border-white/[0.08]">
        <%= status_labels[task.status] %>
      </div>
      <button type="button"
              data-action="click->task-modal#close"
              class="bg-none border-none cursor-pointer text-[#444] text-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/20"
              aria-label="Close panel">✕</button>
    </div>

    <!-- Scrollable content -->
    <div class="flex-1 overflow-y-auto p-5 pb-8 flex flex-col gap-6">

      <%# === Auto-save form: title, notes, priority only === %>
      <%= form_with model: task, url: board_task_path(@board, task), method: :patch, class: "flex flex-col gap-6", data: { task_modal_target: "form" } do |form| %>
        <%= form.hidden_field :priority, value: task.priority, data: { task_modal_target: "priorityField" } %>

        <!-- Title -->
        <div>
          <%= form.text_field :name,
              placeholder: "Task title",
              class: "w-full text-xl font-extrabold text-content tracking-tight leading-tight bg-transparent border-none outline-none p-0 font-inherit",
              data: { task_modal_target: "nameField", action: "input->task-modal#scheduleAutoSave" },
              aria: { label: "Task title" },
              id: "task-modal-title" %>
        </div>

        <!-- Notes -->
        <div class="mt-5">
          <%= form.text_area :description,
              placeholder: "Add notes...",
              class: "w-full min-h-[120px] p-3 rounded-xl border border-white/[0.06] bg-white/[0.03] text-[13px] text-content-secondary resize-y outline-none leading-relaxed font-inherit",
              data: { task_modal_target: "descriptionField", action: "input->task-modal#scheduleAutoSave" },
              aria: { label: "Task notes" } %>
        </div>

        <!-- Hidden submit button (triggered programmatically) -->
        <%= form.submit "Save", class: "hidden", data: { task_modal_target: "submitButton" } %>
      <% end %>

      <%# === Details section: status, priority, agent — outside form === %>
      <div>
        <div class="text-[13px] font-bold text-[#e0e0e0] mb-3.5">Details</div>

        <!-- Status row -->
        <div class="flex items-center justify-between mb-3" data-controller="dropdown">
          <span class="text-[12px] font-medium text-content-muted">Status</span>
          <div class="relative">
            <button type="button" data-action="click->dropdown#toggle" data-dropdown-target="button" aria-expanded="false" aria-label="Status: <%= status_labels[task.status] %>"
                    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg cursor-pointer bg-white/[0.04] border border-white/[0.06] transition-all duration-150 hover:bg-white/[0.06] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/20">
              <div data-task-modal-target="statusDot" class="w-1.5 h-1.5 rounded-full bg-[<%= status_dot_colors[task.status] %>]"></div>
              <span data-task-modal-target="statusLabel" class="text-[12px] font-semibold text-[#ccc]"><%= status_labels[task.status] %></span>
              <svg width="10" height="10" viewBox="0 0 16 16" fill="none" class="opacity-30" aria-hidden="true">
                <path d="M4 6L8 10L12 6" stroke="#888" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div data-dropdown-target="menu" class="hidden absolute top-full right-0 w-[180px] p-1 rounded-xl bg-bg-dropdown border border-white/[0.08] shadow-xl z-10 animate-dropIn">
              <% status_labels.each do |status_key, status_label| %>
                <button type="button"
                        data-action="click->task-modal#changeStatus"
                        data-status="<%= status_key %>"
                        data-status-label="<%= status_label %>"
                        data-status-dot="<%= status_dot_colors[status_key] %>"
                        class="flex items-center gap-2 w-full px-2.5 py-2 rounded-lg cursor-pointer <%= task.status == status_key ? 'bg-white/[0.06]' : 'transparent' %> border-none transition-colors duration-150 text-left"
                        onmouseenter="if(!this.dataset.active)this.classList.add('bg-white/[0.04]')"
                        onmouseleave="if(!this.dataset.active)this.classList.remove('bg-white/[0.04]')">
                  <div class="w-1.5 h-1.5 rounded-full bg-[<%= status_dot_colors[status_key] %>]"></div>
                  <span class="text-[12px] font-semibold <%= task.status == status_key ? 'text-[#e0e0e0]' : 'text-content-muted' %> flex-1"><%= status_label %></span>
                  <% if task.status == status_key %>
                    <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="<%= status_dot_colors[status_key] %>" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <% end %>
                </button>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Priority row -->
        <%
          priority_cycle = %w[none low medium high]
          priority_config = {
            "none"   => { dots: 0, color: "#555",    bg: "rgba(255,255,255,0.03)",  border: "rgba(255,255,255,0.06)" },
            "low"    => { dots: 1, color: "#60a5fa",  bg: "rgba(96,165,250,0.10)",   border: "rgba(96,165,250,0.25)" },
            "medium" => { dots: 2, color: "#fbbf24",  bg: "rgba(251,191,36,0.10)",   border: "rgba(251,191,36,0.25)" },
            "high"   => { dots: 3, color: "#ef4444",  bg: "rgba(239,68,68,0.10)",    border: "rgba(239,68,68,0.25)" },
          }
          current_p = priority_config[task.priority] || priority_config["none"]
        %>
        <div class="flex items-center justify-between mb-3">
          <span class="text-[12px] font-medium text-content-muted">Priority</span>
          <button type="button"
                  data-action="click->task-modal#cyclePriority"
                  data-task-modal-target="priorityButton"
                  data-priority-value="<%= task.priority %>"
                  aria-label="Priority: <%= task.priority %>. Click to change."
                  class="w-[100px] h-[30px] rounded-lg cursor-pointer border flex items-center justify-center gap-0.5 transition-all duration-150 bg-[<%= current_p[:bg] %>] border-[<%= current_p[:border] %>] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/20">
            <% if current_p[:dots] == 0 %>
              <div class="w-1 h-1 rounded-full bg-[#555] opacity-30"></div>
            <% else %>
              <% current_p[:dots].times do %>
                <div class="w-1 h-1 rounded-full bg-[<%= current_p[:color] %>]"></div>
              <% end %>
            <% end %>
          </button>
        </div>

        <%= render "boards/tasks/agent_assignment", task: task, board: @board %>
      </div>

      <!-- Agent Status Banner -->
      <% if task.assigned_to_agent? && task.agent_claimed_at.present? %>
        <% agent_done = task.status == "done" || task.status == "in_review" %>
        <div class="p-3 rounded-xl border flex items-center gap-2 <%= agent_done ? 'bg-[#34d399]/5 border-[#34d399]/10' : 'bg-[#fbbf24]/5 border-[#fbbf24]/10' %>">
          <svg class="w-5 h-5 text-[#fbbf24]" viewBox="0 0 24 24" fill="none"><path d="M12 2a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2 2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z" fill="currentColor"/><path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><rect x="5" y="8" width="14" height="10" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M9 14h6M12 14v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="12" r="1" fill="currentColor"/><circle cx="15" cy="12" r="1" fill="currentColor"/></svg>
          <div>
            <div class="text-[12px] font-semibold <%= agent_done ? 'text-[#34d399]' : 'text-[#fbbf24]' %>">
              <%= agent_done ? 'Agent finished — needs review' : 'Agent is working on this' %>
            </div>
            <div class="text-[11px] font-medium text-[#444] mt-0.5">
              <%= agent_done ? 'Review changes before moving to Done' : 'Check back soon for updates' %>
            </div>
          </div>
        </div>
      <% end %>


      <%# Agent Response / Output %>
      <% if task.output.present? %>
        <div>
          <div class="text-[13px] font-bold text-[#e0e0e0] mb-3.5">Agent Response</div>
          <div class="p-3 rounded-xl border bg-[#34d399]/5 border-[#34d399]/10 flex items-start gap-2">
            <svg class="w-5 h-5 text-[#fbbf24]" viewBox="0 0 24 24" fill="none"><path d="M12 2a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2 2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z" fill="currentColor"/><path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><rect x="5" y="8" width="14" height="10" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M9 14h6M12 14v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="12" r="1" fill="currentColor"/><circle cx="15" cy="12" r="1" fill="currentColor"/></svg>
            <div class="text-[12px] font-medium text-content-secondary leading-relaxed whitespace-pre-wrap flex-1"><%= task.output %></div>
          </div>
        </div>
      <% end %>

      <!-- Subtasks -->
      <% subtasks = task.subtasks %>
      <% if subtasks.any? %>
        <% done_count = subtasks.count(&:done?) %>
        <% total_count = subtasks.size %>
        <% progress = total_count > 0 ? (done_count.to_f / total_count * 100).round : 0 %>
        <div>
          <div class="flex items-center justify-between mb-2">
            <div class="text-[10px] font-bold text-[#444] uppercase tracking-[0.06em]">Subtasks</div>
            <span class="text-[10px] font-semibold text-[#444]"><%= done_count %>/<%= total_count %></span>
          </div>
          <div class="h-0.5 rounded-sm bg-white/[0.05] mb-2.5 overflow-hidden">
            <div class="h-full rounded-sm bg-[<%= board_color_hex %>] opacity-80" style="width:<%= progress %>%"></div>
          </div>
          <div id="task_<%= task.id %>_subtasks" class="flex flex-col gap-0.5">
            <% subtasks.each do |subtask| %>
              <%= button_to board_task_subtask_path(@board, task, subtask),
                  method: :patch,
                  params: { subtask: { done: !subtask.done? } },
                  class: "flex items-center gap-2.5 px-2.5 py-2 rounded-lg bg-white/[0.03] border border-white/[0.04] cursor-pointer" do %>
                <% if subtask.done? %>
                  <div class="w-4 h-4 rounded border-0 bg-[<%= board_color_hex %>] flex items-center justify-center flex-shrink-0">
                    <svg width="9" height="9" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                <% else %>
                  <div class="w-4 h-4 rounded border border-white/20 bg-transparent flex-shrink-0"></div>
                <% end %>
                <span class="text-[12.5px] font-medium <%= subtask.done? ? 'text-[#444] line-through' : 'text-content-secondary' %>"><%= subtask.title %></span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Agent Suggestion Hint -->
      <% if task.agent_hint.present? %>
        <div class="p-3 rounded-xl border bg-[#fbbf24]/4 border-[#fbbf24]/8 flex items-start gap-2">
          <svg class="w-5 h-5 text-[#fbbf24] flex-shrink-0" viewBox="0 0 24 24" fill="none"><path d="M9 21h6M12 3a6 6 0 0 1 4.95 10.05A5 5 0 0 1 12 17a5 5 0 0 1-4.95-3.95A6 6 0 0 1 12 3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <div>
            <div class="text-[12px] font-semibold text-[#fbbf24] mb-0.5">Suggestion</div>
            <div class="text-[12px] font-medium text-content-muted leading-relaxed"><%= task.agent_hint %></div>
          </div>
        </div>
      <% end %>

      <!-- Activity Feed -->
      <div>
        <div class="text-[13px] font-bold text-[#e0e0e0] mb-3.5">Activity</div>
        <%= render "shared/task_activities", task: task %>
      </div>
    </div>
  </div>
</div>
