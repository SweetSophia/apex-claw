<% has_current_user = defined?(current_user) && current_user %>
<% is_done = task.status == "done" %>
<% board_color = task.board.color || "red" %>
<li id="task_<%= task.id %>"
    class="group cursor-grab transition-all duration-150 hover:-translate-y-px p-[10px_12px] bg-white/[0.06] rounded-xl border border-white/[0.08] shadow-[inset_0_1px_0_rgba(255,255,255,0.02)] hover:border-white/[0.12] <%= 'opacity-50' if is_done %>"
    <% if has_current_user %>
      data-controller="dropdown delete-confirm"
      data-action="contextmenu->dropdown#openAtCursor"
      data-delete-confirm-item-name-value="<%= h(task.name.truncate(30)) %>"
    <% end %>
    data-task-id="<%= task.id %>"
    data-task-status="<%= task.status %>"
    data-task-position="<%= task.position %>">

  <%# Context Menu (right-click) - only rendered when current_user is available (not during broadcasts) %>
  <% if has_current_user %>
    <button data-dropdown-target="button" class="hidden" aria-expanded="false"></button>
    <div data-dropdown-target="menu" class="hidden fixed z-[100] min-w-[160px] bg-bg-elevated border border-border rounded-lg shadow-lg py-1">
      <%# Agent Assignment %>
      <% user_agents = current_user.agents.active.where(status: :online).to_a %>
      <% assignment_controls_visible = user_agents.any? || task.assigned_to_agent? || task.assigned_agent_id.present? %>
      <% if assignment_controls_visible %>
        <div class="relative group/agent">
          <button type="button" class="w-full flex items-center justify-between gap-2 px-3 py-2 text-sm text-content-secondary hover:bg-bg-hover transition-colors">
            <span class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-amber-400">
                <path fill-rule="evenodd" d="M12 2a2 2 0 0 1 2 2v2.5a5.5 5.5 0 0 1 2.094 10.416c.112-.37.206-.752.28-1.142A3.5 3.5 0 0 0 12 14.5a3.5 3.5 0 0 0-4.374 1.274c.074.39.168.772.28 1.142A5.5 5.5 0 0 1 10 6.5V4a2 2 0 0 1 2-2Zm-3 9a1 1 0 1 0 0 2 1 1 0 0 0 0-2Zm6 1a1 1 0 1 0 0 2 1 1 0 0 0 0-2Z" clip-rule="evenodd" />
              </svg>
              Assign to Agent
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </button>
          <div class="absolute left-full top-0 ml-1 hidden group-hover/agent:block min-w-[160px] bg-bg-elevated border border-border rounded-lg shadow-lg py-1">
            <% if task.assigned_to_agent? || task.assigned_agent_id.present? %>
              <%= button_to unassign_board_task_path(task.board, task),
                  method: :patch,
                  data: { action: "click->dropdown#close" },
                  class: "w-full flex items-center gap-2 px-3 py-2 text-sm text-red-400 hover:bg-red-500/10 transition-colors" do %>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none" class="w-4 h-4">
                  <path d="M4.5 4.5L11.5 11.5M11.5 4.5L4.5 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                Unassign
              <% end %>
              <div class="border-t border-border my-1"></div>
            <% end %>
            <%= button_to assign_board_task_path(task.board, task),
                method: :patch,
                params: { agent_id: "" },
                data: { action: "click->dropdown#close" },
                class: "w-full flex items-center gap-2 px-3 py-2 text-sm text-content-secondary hover:bg-bg-hover transition-colors" do %>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 text-amber-400">
                <path fill-rule="evenodd" d="M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13ZM.75 8a7.25 7.25 0 0 1 13.538-4.245A7.25 7.25 0 0 1 7.26 14.69 7.25 7.25 0 0 1 .75 8Z" clip-rule="evenodd" />
              </svg>
              Auto / Any
            <% end %>
            <% user_agents.each do |agent| %>
              <%= button_to assign_board_task_path(task.board, task),
                  method: :patch,
                  params: { agent_id: agent.id },
                  data: { action: "click->dropdown#close" },
                  class: "w-full flex items-center gap-2 px-3 py-2 text-sm text-content-secondary hover:bg-bg-hover transition-colors #{task.assigned_agent_id == agent.id ? 'bg-white/[0.04]' : ''}" do %>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-amber-400">
                  <path fill-rule="evenodd" d="M12 2a2 2 0 0 1 2 2v2.5a5.5 5.5 0 0 1 2.094 10.416c.112-.37.206-.752.28-1.142A3.5 3.5 0 0 0 12 14.5a3.5 3.5 0 0 0-4.374 1.274c.074.39.168.772.28 1.142A5.5 5.5 0 0 1 10 6.5V4a2 2 0 0 1 2-2Zm-3 9a1 1 0 1 0 0 2 1 1 0 0 0 0-2Zm6 1a1 1 0 1 0 0 2 1 1 0 0 0 0-2Z" clip-rule="evenodd" />
                </svg>
                <span class="flex-1 truncate"><%= agent.name %></span>
                <% if task.assigned_agent_id == agent.id %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-accent">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </div>
        <div class="border-t border-border my-1"></div>
      <% end %>

      <%# Priority Selection - Submenu %>
      <div class="relative group/priority">
        <button type="button" class="w-full flex items-center justify-between gap-2 px-3 py-2 text-sm text-content-secondary hover:bg-bg-hover transition-colors">
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" />
            </svg>
            Priority
          </span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
        </button>
        <%# Submenu %>
        <div class="absolute left-full top-0 ml-1 hidden group-hover/priority:block min-w-[140px] bg-bg-elevated border border-border rounded-lg shadow-lg py-1">
          <% [
            ["none", "None", nil, "text-content-muted"],
            ["low", "Low", 1, "text-yellow-500"],
            ["medium", "Medium", 2, "text-orange-500"],
            ["high", "High", 3, "text-accent"]
          ].each do |priority, label, flame_count, color| %>
            <%= button_to board_task_path(task.board, task),
                method: :patch,
                params: { task: { priority: priority } },
                data: { action: "click->dropdown#close" },
                class: "w-full flex items-center justify-between gap-3 px-3 py-2 text-sm text-content-secondary hover:bg-bg-hover transition-colors" do %>
              <span class="flex items-center gap-2">
                <% if flame_count.nil? %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 <%= color %>">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" />
                  </svg>
                <% else %>
                    <span class="flex -space-x-1.5">
                      <% flame_count.times do |i| %>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 <%= color %> relative" style="z-index: <%= flame_count - i %>;">
                          <path fill-rule="evenodd" d="M12.963 2.286a.75.75 0 0 0-1.071-.136 9.742 9.742 0 0 0-3.539 6.176 7.547 7.547 0 0 1-1.705-1.715.75.75 0 0 0-1.152-.082A9 9 0 1 0 15.68 4.534a7.46 7.46 0 0 1-2.717-2.248ZM15.75 14.25a3.75 3.75 0 1 1-7.313-1.172c.628.465 1.35.81 2.133 1a5.99 5.99 0 0 1 1.925-3.546 3.75 3.75 0 0 1 3.255 3.718Z" clip-rule="evenodd" />
                        </svg>
                      <% end %>
                    </span>
                <% end %>
                <%= label %>
              </span>
              <% if task.priority == priority %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-accent">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
      <div class="border-t border-border my-1"></div>

      <%# Delete Button - opens modal that's outside the dropdown %>
      <button type="button"
              data-action="click->delete-confirm#open click->dropdown#close"
              class="w-full flex items-center gap-2 px-3 py-2 text-sm text-red-400 hover:bg-red-500/10 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
        </svg>
        Delete
      </button>
    </div>

    <%# Delete Confirmation Modal - outside the dropdown so it's not hidden when dropdown closes %>
    <%= render "application/delete_modal", url: board_task_path(task.board, task) %>
  <% end %>

  <%# Compute metadata flags %>
  <% subtask_total = task.respond_to?(:subtasks) ? task.subtasks.size : 0 %>
  <% subtask_done = subtask_total > 0 ? task.subtasks.count(&:done?) : 0 %>
  <%
    priority_dot_config = {
      "low" => { dots: 1, color: "#60a5fa" },
      "medium" => { dots: 2, color: "#fbbf24" },
      "high" => { dots: 3, color: "#ef4444" },
    }
    show_priority = task.priority.present? && task.priority != "none" && priority_dot_config[task.priority]
    p_cfg = priority_dot_config[task.priority]
    has_agent = task.assigned_to_agent?
    has_assigned_agent = task.assigned_agent_id.present? && task.assigned_agent.present?
    has_claimed_agent = task.claimed_by_agent_id.present? && task.claimed_by_agent.present?
    has_hint = task.respond_to?(:agent_hint) && task.agent_hint.present? && !is_done
    has_metadata = show_priority || subtask_total > 0 || has_agent || has_hint
  %>

  <%= link_to board_task_path(task.board, task), data: { turbo_frame: "task_panel" }, class: "block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/30 focus-visible:ring-inset rounded-lg", aria_label: "Open task: #{task.name}" do %>

  <%# Task Title %>
  <div class="flex items-center <%= is_done ? 'text-[#6a6a70]' : 'text-[#f0f0f0]' %> <%= 'mb-2' if has_metadata %>">
    <span class="text-[13px] font-semibold leading-[1.35]"><%= task.name %></span>
    <div class="opacity-0 group-hover:opacity-100 transition-opacity ml-auto pl-2 self-center">
      <svg width="12" height="12" viewBox="0 0 16 16" fill="none" class="text-[#555]">
        <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>

  <%# Priority dots + subtasks row %>
  <% if show_priority || subtask_total > 0 %>
    <div class="flex items-center gap-2 flex-wrap">
      <% if show_priority %>
        <div class="flex items-center gap-0.5">
          <% p_cfg[:dots].times do %>
            <div class="w-1 h-1 rounded-full bg-[<%= p_cfg[:color] %>]"></div>
          <% end %>
        </div>
      <% end %>
          <% if subtask_total > 0 %>
        <div class="flex items-center gap-1">
          <% if subtask_done == subtask_total %>
            <svg width="10" height="10" viewBox="0 0 16 16" fill="none">
              <rect x="1" y="1" width="14" height="14" rx="3" fill="currentColor" fill-opacity="0.15" stroke="currentColor" stroke-width="1.5"/>
              <path d="M4 8.5L6.5 11L12 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          <% else %>
            <svg width="10" height="10" viewBox="0 0 16 16" fill="none" class="text-[#8d8d92]">
              <rect x="1" y="1" width="14" height="14" rx="3" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          <% end %>
          <span class="text-[10px] font-medium text-[#8d8d92]"><%= subtask_done %>/<%= subtask_total %></span>
          <div class="h-[3px] w-8 rounded overflow-hidden bg-white/[0.06]" style="width: <%= subtask_total > 0 ? (subtask_done.to_f / subtask_total * 100).round : 0 %>%; background: <%= board_hex_color(task.board) %>; opacity: 0.7"></div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Agent status pill %>
  <% if has_agent || has_claimed_agent %>
    <% agent_done = task.status == "done" || task.status == "in_review" %>
    <div class="flex items-center gap-1 mt-2 px-1.5 py-1 rounded-md w-fit" style="background: <%= agent_done ? 'rgba(52,211,153,0.10)' : 'rgba(251,191,36,0.10)' %>; border-color: <%= agent_done ? 'rgba(52,211,153,0.25)' : 'rgba(251,191,36,0.25)' %>">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3 text-amber-400">
        <path fill-rule="evenodd" d="M12 2a2 2 0 0 1 2 2v2.5a5.5 5.5 0 0 1 2.094 10.416c.112-.37.206-.752.28-1.142A3.5 3.5 0 0 0 12 14.5a3.5 3.5 0 0 0-4.374 1.274c.074.39.168.772.28 1.142A5.5 5.5 0 0 1 10 6.5V4a2 2 0 0 1 2-2Zm-3 9a1 1 0 1 0 0 2 1 1 0 0 0 0-2Zm6 1a1 1 0 1 0 0 2 1 1 0 0 0 0-2Z" clip-rule="evenodd" />
      </svg>
      <% if has_claimed_agent %>
        <span class="text-[9px] font-semibold <%= agent_done ? 'text-emerald-400' : 'text-amber-400' %>"><%= task.claimed_by_agent.name.truncate(12) %> <%= agent_done ? '✓' : '⋯' %></span>
      <% elsif has_assigned_agent %>
        <span class="text-[9px] font-semibold <%= agent_done ? 'text-emerald-400' : 'text-amber-400' %>"><%= task.assigned_agent.name.truncate(12) %> (queued)</span>
      <% else %>
        <span class="text-[9px] font-semibold <%= agent_done ? 'text-emerald-400' : 'text-amber-400' %>"><%= agent_done ? 'Review' : 'Working' %></span>
      <% end %>
      <% unless agent_done %>
        <div class="w-1 h-1 rounded-full bg-amber-400 animate-pulse"></div>
      <% end %>
    </div>
  <% end %>

  <%# Agent hint %>
  <% if has_hint %>
    <div class="flex items-center gap-1.5 mt-2 px-2 py-1 rounded-md w-fit" style="background: rgba(251,191,36,0.05); border-color: rgba(251,191,36,0.08)">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3 text-amber-400">
        <path d="M8 1.5a4.5 4.5 0 0 1 2.753 8.145c.05.082.1.163.157.244A3.5 3.5 0 0 0 8 14.5a3.5 3.5 0 0 0 2.09-6.367 5.005 5.005 0 0 0 2.41-1.633.75.75 0 0 0-.22-1.155 4.5 4.5 0 1 1-5.56-5.56.75.75 0 0 0-1.155-.22A5.005 5.005 0 0 0 2.409 6.6 3.5 3.5 0 0 0 8 1.5ZM7 5.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM6.5 9a1 1 0 0 0 0 2h3a1 1 0 0 0 0-2h-3Z"/>
      </svg>
      <span class="text-[10px] font-medium text-[#888] italic leading-[1.3]"><%= task.agent_hint %></span>
    </div>
  <% end %>

  <% end %>
</li>
