<% content_for :title, "#{@board.name} - clawdeck" %>
<% @board_page = true %>

<%# Subscribe to real-time updates for this board %>
<%= turbo_stream_from "board_#{@board.id}" %>

<div class="h-full flex flex-col" data-controller="board task-board">
  <%# Unified Navbar %>
  <%= render "shared/navbar" %>

  <%# Board modals (new board, settings) %>
  <%= render "boards/header" %>

  <%# Tag filter indicator %>
  <% if @current_tag.present? %>
    <div class="flex items-center gap-2 px-4 py-2 border-b border-border bg-bg-surface/90">
      <span class="text-[11px] uppercase tracking-[0.08em] text-content-muted">Filtered by</span>
      <span class="inline-flex items-center gap-1 rounded-full border border-white/[0.08] bg-white/[0.04] px-2 py-0.5 text-xs font-medium text-content">
        <%= @current_tag %>
        <%= link_to board_path(@board, view: @view_mode), class: "ml-1 hover:text-status-error" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3">
            <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
          </svg>
        <% end %>
      </span>
    </div>
  <% end %>

  <% if @view_mode == "timeline" %>
    <%= render "boards/timeline" %>
  <% else %>
    <%# Kanban Columns - compact board layout with fixed-width lanes %>
    <div class="flex-1 overflow-auto bg-bg-base" id="board-view-panel">
      <div class="flex min-h-full items-start gap-3 px-4 py-3 overflow-x-auto">
        <% Task.statuses.keys.each do |status| %>
          <%= render "boards/column", status: status, tasks: @columns[status.to_sym] %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Task Panel Container - loaded via Turbo Frame %>
  <% if @selected_task %>
    <%= turbo_frame_tag "task_panel" do %>
      <%= render "boards/tasks/panel", task: @selected_task %>
    <% end %>
  <% else %>
    <%= turbo_frame_tag "task_panel" %>
  <% end %>

  <%# New Task Modal %>
  <% if @task %>
    <%= render template: "boards/tasks/new" %>
  <% else %>
    <%= turbo_frame_tag "new_task_modal" %>
  <% end %>

</div>
