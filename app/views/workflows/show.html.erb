<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <%= link_to "← Workflows", workflows_path, class: "text-xs text-[#888] hover:text-amber-400 transition-colors" %>
      <h1 class="text-lg font-semibold text-[#e0e0e0] mt-2"><%= @workflow.name %></h1>
      <% if @workflow.description.present? %>
        <p class="text-xs text-[#666] mt-1"><%= @workflow.description %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-2">
      <%= button_to "Run Now",
            run_workflow_path(@workflow),
            method: :post,
            form: { data: { turbo_confirm: "Run this workflow now?" } },
            class: "px-3 py-1.5 text-xs font-medium rounded-md bg-amber-400 text-[#161619] hover:bg-amber-500 transition-colors cursor-pointer" %>
    </div>
  </div>

  <div id="workflow_form" class="p-5 rounded-lg bg-[#1e1e22] border border-white/[0.08]">
    <div class="text-xs font-semibold text-[#555] uppercase tracking-wider mb-3">Edit Workflow</div>
    <%= render "workflows/form", workflow: @workflow, agents: current_user.agents.active %>
  </div>

  <%# Run history %>
  <div class="mt-8">
    <div class="text-xs font-semibold text-[#555] uppercase tracking-wider mb-3">Run History</div>
    <% if @runs.any? %>
      <div class="space-y-2">
        <% @runs.each do |run| %>
          <div class="flex items-center justify-between p-3 rounded-lg bg-[#1e1e22] border border-white/[0.08]">
            <div class="flex items-center gap-3">
              <span class="text-[10px] px-1.5 py-0.5 rounded
                <%= run.status == 'completed' ? 'bg-emerald-500/10 text-emerald-400' : '' %>
                <%= run.status == 'failed' ? 'bg-red-500/10 text-red-400' : '' %>
                <%= run.status == 'running' ? 'bg-amber-400/10 text-amber-400' : '' %>
                <%= run.status == 'pending' ? 'bg-white/[0.05] text-[#666]' : '' %>">
                <%= run.status.humanize %>
              </span>
              <span class="text-xs text-[#888]"><%= run.trigger_type.humanize %></span>
              <span class="text-xs text-[#555]"><%= run.created_at.strftime("%b %d, %H:%M") %></span>
            </div>
            <% if run.error_message.present? %>
              <span class="text-xs text-red-400 truncate max-w-[200px]" title="<%= run.error_message %>"><%= run.error_message %></span>
            <% elsif run.result.present? %>
              <span class="text-xs text-[#555] truncate max-w-[200px]"><%= run.result.except("task_id").map { |k, v| "#{k}: #{v}" }.join(", ") %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-xs text-[#666] py-3">No runs yet.</div>
    <% end %>
  </div>
</div>
