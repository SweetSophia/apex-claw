<%= tag.div id: dom_id(workflow), class: "mb-3 p-4 rounded-xl bg-bg-card border border-white/[0.06] group hover:border-white/[0.12] transition-colors cursor-pointer" do %>
  <div class="flex items-start justify-between">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <h3 class="text-[14px] font-medium text-content truncate"><%= workflow.name %></h3>
        <span class="text-[10px] px-1.5 py-0.5 rounded-full <%= workflow.status == 'active' ? 'bg-[#34d399]/10 text-[#34d399]' : 'bg-white/[0.05] text-content-muted' %>">
          <%= workflow.status.humanize %>
        </span>
      </div>
      <% if workflow.description.present? %>
        <p class="text-[12px] text-content-muted mt-1 truncate"><%= workflow.description %></p>
      <% end %>
      <div class="text-[12px] text-content-muted mt-2">
        <%= workflow.trigger_type.humanize %> ·
        <%= workflow.execution_mode.humanize %> ·
        Agent: <%= workflow.agent&.name || "Unassigned" %>
        <% if workflow.last_run_at %>
          · Last run <%= time_ago_in_words(workflow.last_run_at) %> ago
        <% end %>
      </div>
    </div>
    <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
      <%= button_to "Run",
            run_workflow_path(workflow),
            method: :post,
            form: { data: { turbo_confirm: "Run this workflow now?" } },
            class: "text-[12px] text-[#fbbf24] hover:text-[#fbbf24]/80 transition-colors cursor-pointer" %>
      <%= link_to "Edit", workflow_path(workflow), class: "text-[12px] text-content-muted hover:text-[#fbbf24] transition-colors cursor-pointer" %>
      <%= button_to "Delete", workflow_path(workflow), method: :delete,
            form: { data: { turbo_confirm: "Delete this workflow?" } },
            class: "text-[12px] text-red-400 hover:text-red-300 transition-colors cursor-pointer" %>
    </div>
  </div>
<% end %>
