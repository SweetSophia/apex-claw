<%= tag.div id: dom_id(workflow), class: "mb-3 p-4 rounded-lg bg-[#1e1e22] border border-white/[0.08] group" do %>
  <div class="flex items-start justify-between">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <h3 class="text-sm font-medium text-[#e0e0e0] truncate"><%= workflow.name %></h3>
        <span class="text-[10px] px-1.5 py-0.5 rounded <%= workflow.status == 'active' ? 'bg-emerald-500/10 text-emerald-400' : 'bg-white/[0.05] text-[#666]' %>">
          <%= workflow.status.humanize %>
        </span>
      </div>
      <% if workflow.description.present? %>
        <p class="text-xs text-[#666] mt-1 truncate"><%= workflow.description %></p>
      <% end %>
      <div class="text-xs text-[#555] mt-2">
        <%= workflow.trigger_type.humanize %> ·
        <%= workflow.execution_mode.humanize %> ·
        Agent: <%= workflow.agent&.name || "Unassigned" %>
        <% if workflow.last_run_at %>
          · Last run <%= time_ago_in_words(workflow.last_run_at) %> ago
        <% end %>
      </div>
    </div>
    <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
      <%= button_to "Run",
            run_workflow_path(workflow),
            method: :post,
            form: { data: { turbo_confirm: "Run this workflow now?" } },
            class: "text-xs text-amber-400 hover:text-amber-300 transition-colors" %>
      <%= link_to "Edit", workflow_path(workflow), class: "text-xs text-[#888] hover:text-amber-400 transition-colors" %>
      <%= button_to "Delete", workflow_path(workflow), method: :delete,
            form: { data: { turbo_confirm: "Delete this workflow?" } },
            class: "text-xs text-red-400 hover:text-red-300 transition-colors" %>
    </div>
  </div>
<% end %>
