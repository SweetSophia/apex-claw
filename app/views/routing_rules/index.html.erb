<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-xl font-semibold text-content">Routing Rules</h1>
      <p class="text-xs text-content-secondary mt-1">Auto-assign tasks to agents based on skills, priority, and tags.</p>
    </div>
  </div>

  <div id="rule_form" class="mb-8 p-5 rounded-lg bg-bg-card border border-white/[0.08]">
    <div class="text-xs font-semibold text-content-muted uppercase tracking-wider mb-3">New Routing Rule</div>
    <%= render "routing_rules/form", rule: (@rule || RoutingRule.new), agents: current_user.agents.active %>
  </div>

  <div id="rules_list">
    <% if @rules.any? %>
      <%= render partial: "routing_rules/rule_card", collection: @rules, as: :rule %>
    <% else %>
      <div class="text-center py-12 text-content-secondary">
        <p class="text-sm">No routing rules yet. Create your first rule above.</p>
      </div>
    <% end %>
  </div>
</div>
