<% conditions = @rule.conditions.presence || {} %>
<% summary_parts = [] %>
<% summary_parts << "skills: #{Array(conditions["skills"]).join(", ")}" if Array(conditions["skills"]).any? %>
<% summary_parts << "priority: #{conditions["priority"]}" if conditions["priority"].present? %>
<% summary_parts << "tags: #{Array(conditions["tags"]).join(", ")}" if Array(conditions["tags"]).any? %>
<% summary_parts << "status: #{conditions["status"]}" if conditions["status"].present? %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <%= link_to "← Routing Rules", routing_rules_path, class: "text-xs text-[#888] hover:text-amber-400 transition-colors" %>
      <h1 class="text-lg font-semibold text-[#e0e0e0] mt-2"><%= @rule.name %></h1>
      <p class="text-xs text-[#666] mt-1"><%= summary_parts.any? ? summary_parts.join(" · ") : "Matches all new tasks before lower-priority fallback rules." %></p>
    </div>
  </div>

  <div id="rule_form" class="p-5 rounded-lg bg-[#1e1e22] border border-white/[0.08]">
    <div class="text-xs font-semibold text-[#555] uppercase tracking-wider mb-3">Edit Routing Rule</div>
    <%= render "routing_rules/form", rule: @rule, agents: current_user.agents.active %>
  </div>

  <div class="mt-8">
    <div class="text-xs font-semibold text-[#555] uppercase tracking-wider mb-3">Match Preview</div>
    <div class="p-5 rounded-lg bg-[#1e1e22] border border-white/[0.08] space-y-4">
      <div class="grid gap-3 sm:grid-cols-2">
        <div>
          <div class="text-[11px] uppercase tracking-wider text-[#555] mb-1">Target Agent</div>
          <div class="text-sm text-[#e0e0e0]"><%= @rule.agent&.name || "Unassigned" %></div>
        </div>
        <div>
          <div class="text-[11px] uppercase tracking-wider text-[#555] mb-1">Rule Priority</div>
          <div class="text-sm text-[#e0e0e0]"><%= @rule.priority %></div>
        </div>
        <div>
          <div class="text-[11px] uppercase tracking-wider text-[#555] mb-1">Required Skills</div>
          <div class="text-sm text-[#e0e0e0]"><%= Array(conditions["skills"]).presence&.join(", ") || "Any" %></div>
        </div>
        <div>
          <div class="text-[11px] uppercase tracking-wider text-[#555] mb-1">Required Tags</div>
          <div class="text-sm text-[#e0e0e0]"><%= Array(conditions["tags"]).presence&.join(", ") || "Any" %></div>
        </div>
        <div>
          <div class="text-[11px] uppercase tracking-wider text-[#555] mb-1">Task Priority</div>
          <div class="text-sm text-[#e0e0e0]"><%= conditions["priority"].presence || "Any" %></div>
        </div>
        <div>
          <div class="text-[11px] uppercase tracking-wider text-[#555] mb-1">Task Status</div>
          <div class="text-sm text-[#e0e0e0]"><%= conditions["status"].presence || "Any" %></div>
        </div>
      </div>

      <p class="text-xs text-[#666] leading-relaxed">
        Matching tasks must satisfy every condition you set here. When this rule is active, ClawDeck checks it in descending priority order and assigns matching tasks to <span class="text-amber-400"><%= @rule.agent&.name || "the selected agent" %></span>.
      </p>
    </div>
  </div>
</div>
