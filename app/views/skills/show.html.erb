<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <%= link_to "← Skills", skills_path, class: "text-xs text-[#888] hover:text-amber-400 transition-colors" %>
      <h1 class="text-lg font-semibold text-[#e0e0e0] mt-2"><%= @skill.name %></h1>
      <% if @skill.description.present? %>
        <p class="text-xs text-[#666] mt-1"><%= @skill.description %></p>
      <% end %>
    </div>
  </div>

  <div id="skill_form" class="p-5 rounded-lg bg-[#1e1e22] border border-white/[0.08]">
    <div class="text-xs font-semibold text-[#555] uppercase tracking-wider mb-3">Edit Skill</div>
    <%= render "skills/form", skill: @skill %>
  </div>

  <% if @skill.agents.any? %>
    <div class="mt-6">
      <div class="text-xs font-semibold text-[#555] uppercase tracking-wider mb-3">Assigned Agents</div>
      <div class="space-y-2">
        <% @skill.agents.each do |agent| %>
          <div class="flex items-center justify-between p-3 rounded-lg bg-[#1e1e22] border border-white/[0.08]">
            <span class="text-sm text-[#e0e0e0]"><%= agent.name %></span>
            <span class="text-xs text-[#555]"><%= agent.status %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>