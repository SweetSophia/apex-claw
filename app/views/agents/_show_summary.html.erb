<% health_stats ||= {} %>
<% completed_count = health_stats.fetch(:completed, agent.recent_completed_tasks_count) %>
<% command_count = health_stats.fetch(:commands, agent.recent_commands_count) %>
<% failed_count = health_stats.fetch(:failed, agent.recent_failed_commands_count) %>
<% pending_count = health_stats.fetch(:pending, agent.pending_commands_count) %>
<% claimed_count = health_stats.fetch(:claimed_count, agent.claimed_tasks.count) %>
<% assigned_count = health_stats.fetch(:assigned_count, agent.assigned_tasks.count) %>
<% error_rate = health_stats.fetch(:error_rate, agent.recent_command_error_rate) %>
<% alerts = agent.health_alerts(health_stats: health_stats) %>
<% owner_label = agent.user.respond_to?(:email_address) ? agent.user.email_address : agent.user.try(:email) %>

<div id="agent_show_summary_<%= agent.id %>">
  <div class="mb-8 rounded-[1.5rem] border border-white/[0.08] bg-[#1e1e22] p-6 shadow-[0_24px_60px_rgba(0,0,0,0.28)]">
    <div class="flex flex-col gap-5 xl:flex-row xl:items-start xl:justify-between">
      <div class="min-w-0 flex items-start gap-4">
        <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl border border-white/[0.08] bg-black/20 text-2xl shadow-inner shadow-black/20">
          <%= agent_status_icon(agent) %>
        </div>

        <div class="min-w-0">
          <div class="flex flex-wrap items-center gap-2.5">
            <h1 class="text-2xl font-extrabold tracking-tight text-[#e0e0e0]"><%= agent.name %></h1>
            <span class="rounded-full px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.2em] <%= agent_status_badge_classes(agent) %>"><%= agent.status.humanize %></span>
            <span class="rounded-full px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.2em] <%= agent_health_badge_classes(agent) %>"><%= agent.health_badge_label %></span>
            <span class="rounded-full px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.2em] <%= agent_last_seen_badge_classes(agent) %>"><%= agent.last_seen_state.to_s.humanize %></span>
          </div>

          <div class="mt-2 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-[#666]">
            <% if agent.hostname.present? %>
              <span><%= agent.hostname %></span>
              <span class="text-[#444]">•</span>
            <% end %>
            <span><%= agent.runtime_provider %></span>
            <% if agent.platform.present? %>
              <span class="text-[#444]">•</span>
              <span><%= agent.platform %></span>
            <% end %>
            <% if agent.version.present? %>
              <span class="text-[#444]">•</span>
              <span>v<%= agent.version %></span>
            <% end %>
          </div>

          <div class="mt-3 text-sm text-[#b6b6bc]">
            <span class="font-medium text-[#e0e0e0]">Runtime:</span>
            <%= agent.runtime_provider %>
            <span class="mx-2 text-[#444]">•</span>
            <span class="font-medium text-[#e0e0e0]">Last seen:</span>
            <%= agent.last_seen_label %>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <% if agent.online? || agent.draining? %>
          <% if agent.online? %>
            <%= button_to agent_commands_path(agent),
                params: { agent_command: { kind: "drain", payload: { reason: "manual" }.to_json } },
                class: "inline-flex items-center gap-1.5 rounded-xl border border-yellow-400/15 bg-yellow-500/15 px-3 py-2 text-xs font-semibold text-yellow-300 transition-colors hover:bg-yellow-500/25",
                data: { confirm: "Drain this agent? It will stop accepting new tasks." } do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v9a2.25 2.25 0 0 0 2.25 2.25h3a2.25 2.25 0 0 0 2.25-2.25V15Z" />
              </svg>
              Drain
            <% end %>
          <% end %>

          <% if agent.draining? %>
            <%= button_to agent_commands_path(agent),
                params: { agent_command: { kind: "resume", payload: {}.to_json } },
                class: "inline-flex items-center gap-1.5 rounded-xl border border-emerald-400/15 bg-emerald-500/15 px-3 py-2 text-xs font-semibold text-emerald-300 transition-colors hover:bg-emerald-500/25",
                data: { confirm: "Resume this agent? It will start accepting new tasks." } do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
              </svg>
              Resume
            <% end %>
          <% end %>

          <%= button_to agent_commands_path(agent),
              params: { agent_command: { kind: "restart", payload: {}.to_json } },
              class: "inline-flex items-center gap-1.5 rounded-xl border border-white/[0.08] bg-white/[0.04] px-3 py-2 text-xs font-semibold text-[#c3c3c8] transition-colors hover:bg-white/[0.08]",
              data: { confirm: "Restart OpenClaw on this agent?" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
            Restart
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-2 gap-3 xl:grid-cols-7">
      <div class="rounded-xl border border-white/[0.06] bg-black/20 p-4">
        <div class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#555]">Status</div>
        <div class="mt-2 text-lg font-bold text-[#e0e0e0]"><%= agent.health_badge_label %></div>
        <div class="mt-1 text-xs text-[#666]"><%= agent.status.humanize %> · <%= agent.last_seen_state.to_s.humanize.downcase %></div>
      </div>

      <div class="rounded-xl border border-white/[0.06] bg-black/20 p-4">
        <div class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#555]">Last Seen</div>
        <div class="mt-2 text-lg font-bold text-[#e0e0e0]"><%= agent.last_seen_label %></div>
        <div class="mt-1 text-xs text-[#666]"><%= agent.last_heartbeat_at ? agent.last_heartbeat_at.strftime("%b %d, %H:%M") : "No heartbeat yet" %></div>
      </div>

      <div class="rounded-xl border border-white/[0.06] bg-black/20 p-4">
        <div class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#555]">Provider</div>
        <div class="mt-2 text-lg font-bold text-[#e0e0e0]"><%= agent.runtime_provider %></div>
        <div class="mt-1 text-xs text-[#666]"><%= agent.model.presence || "Runtime managed" %></div>
      </div>

      <div class="rounded-xl border border-white/[0.06] bg-black/20 p-4">
        <div class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#555]">Owner</div>
        <div class="mt-2 text-lg font-bold text-[#e0e0e0]"><%= owner_label.to_s.split("@").first.presence || owner_label %></div>
        <div class="mt-1 truncate text-xs text-[#666]"><%= owner_label %></div>
      </div>

      <div class="rounded-xl border border-white/[0.06] bg-black/20 p-4">
        <div class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#555]">Uptime</div>
        <div class="mt-2 text-lg font-bold text-[#e0e0e0]"><%= agent.uptime_label %></div>
        <div class="mt-1 text-xs <%= agent.task_runner_active? ? 'text-emerald-300' : 'text-amber-300' %>"><%= agent.task_runner_active? ? "Task runner active" : "Task runner idle" %></div>
      </div>

      <div class="rounded-xl border border-white/[0.06] bg-black/20 p-4">
        <div class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#555]">Open Tasks</div>
        <div class="mt-2 text-lg font-bold text-[#e0e0e0]"><%= claimed_count %> claimed</div>
        <div class="mt-1 text-xs text-[#666]"><%= assigned_count %> assigned</div>
      </div>

      <div class="rounded-xl border border-white/[0.06] bg-black/20 p-4">
        <div class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#555]">Command Health</div>
        <div class="mt-2 text-lg font-bold text-[#e0e0e0]"><%= error_rate %>% error rate</div>
        <div class="mt-1 text-xs text-[#666]"><%= command_count %> commands · <%= failed_count %> failed · <%= completed_count %> tasks done</div>
      </div>

      <div class="rounded-xl border border-white/[0.06] bg-black/20 p-4">
        <div class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#555]">Pending Commands</div>
        <div class="mt-2 text-lg font-bold text-[#e0e0e0]"><%= pending_count %></div>
        <div class="mt-1 text-xs text-[#666]"><%= pending_count.positive? ? "Queue needs attention" : "Queue is clear" %></div>
      </div>
    </div>

    <% if alerts.any? %>
      <div class="mt-6 rounded-2xl border border-amber-400/20 bg-amber-400/10 p-4">
        <div class="flex items-center gap-2 text-sm font-semibold text-amber-300">
          <span>Runtime alerts</span>
          <span class="rounded-full bg-amber-400/15 px-2 py-0.5 text-[10px] uppercase tracking-[0.2em] text-amber-200"><%= pluralize(alerts.size, "alert") %></span>
        </div>

        <div class="mt-3 grid gap-2 lg:grid-cols-2">
          <% alerts.each do |alert| %>
            <div class="rounded-xl border border-amber-400/10 bg-black/10 px-3 py-2 text-sm text-[#f5e7b2]">
              <span class="text-amber-300">•</span>
              <%= alert %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
