<% health_stats ||= {} %>
<% completed_count = health_stats.fetch(:completed, agent.recent_completed_tasks_count) %>
<% assigned_count = health_stats.fetch(:assigned_count, agent.assigned_tasks.count) %>
<% claimed_count = health_stats.fetch(:claimed_count, agent.claimed_tasks.count) %>
<% pending_count = health_stats.fetch(:pending, agent.pending_commands_count) %>
<% error_rate = health_stats.fetch(:error_rate, agent.recent_command_error_rate) %>
<% alerts = agent.health_alerts(health_stats: health_stats) %>

<div id="agent_<%= agent.id %>" class="block rounded-2xl border border-white/[0.08] bg-[#1e1e22] p-4 shadow-[0_18px_40px_rgba(0,0,0,0.22)] transition-all hover:-translate-y-0.5 hover:border-white/[0.14] hover:bg-white/[0.04]">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div class="min-w-0 flex items-start gap-3">
      <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-white/[0.08] bg-black/20 text-lg shadow-inner shadow-black/20">
        <%= agent_status_icon(agent) %>
      </div>

      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-2">
          <span class="truncate text-sm font-bold text-[#e0e0e0]"><%= agent.name %></span>
          <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.18em] <%= agent_status_badge_classes(agent) %>"><%= agent.status.humanize %></span>
          <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.18em] <%= agent_health_badge_classes(agent) %>"><%= agent.health_badge_label %></span>
        </div>

        <div class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-[#666]">
          <% if agent.hostname.present? %>
            <span><%= agent.hostname %></span>
            <span class="text-[#444]">•</span>
          <% end %>
          <span><%= agent.runtime_provider %></span>
          <% if agent.version.present? %>
            <span class="text-[#444]">•</span>
            <span>v<%= agent.version %></span>
          <% end %>
          <% if agent.platform.present? %>
            <span class="text-[#444]">•</span>
            <span><%= agent.platform %></span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="flex flex-col items-start gap-2 text-left lg:items-end lg:text-right">
      <div>
        <div class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#555]">Last seen</div>
        <div class="mt-1 text-sm font-semibold text-[#e0e0e0]"><%= agent.last_seen_label %></div>
      </div>

      <div class="flex flex-wrap gap-1.5 lg:justify-end">
        <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.18em] <%= agent_last_seen_badge_classes(agent) %>"><%= agent.last_seen_state.to_s.humanize %></span>
        <% if pending_count.positive? %>
          <span class="rounded-full bg-white/[0.06] px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.18em] text-[#fbbf24]"><%= pluralize(pending_count, "pending command") %></span>
        <% end %>
      </div>

      <% if agent.tags.any? %>
        <div class="flex flex-wrap gap-1 lg:justify-end">
          <% agent.tags.first(3).each do |tag| %>
            <span class="rounded-full bg-white/[0.06] px-2 py-0.5 text-[9px] font-medium text-[#8a8a92]"><%= tag %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-4 grid grid-cols-2 gap-2 lg:grid-cols-4">
    <div class="rounded-xl border border-white/[0.05] bg-black/20 px-3 py-2.5">
      <div class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#555]">Uptime</div>
      <div class="mt-1 text-sm font-semibold text-[#d9d9de]"><%= agent.uptime_label %></div>
      <div class="mt-1 text-[11px] <%= agent.task_runner_active? ? 'text-emerald-300' : 'text-amber-300' %>"><%= agent.task_runner_active? ? "Runner active" : "Runner idle" %></div>
    </div>

    <div class="rounded-xl border border-white/[0.05] bg-black/20 px-3 py-2.5">
      <div class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#555]">Open Tasks</div>
      <div class="mt-1 text-sm font-semibold text-[#d9d9de]"><%= claimed_count %> claimed</div>
      <div class="mt-1 text-[11px] text-[#666]"><%= assigned_count %> assigned</div>
    </div>

    <div class="rounded-xl border border-white/[0.05] bg-black/20 px-3 py-2.5">
      <div class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#555]">Command Health</div>
      <div class="mt-1 text-sm font-semibold text-[#d9d9de]"><%= error_rate %>% error rate</div>
      <div class="mt-1 text-[11px] text-[#666]"><%= pending_count %> pending now</div>
    </div>

    <div class="rounded-xl border border-white/[0.05] bg-black/20 px-3 py-2.5">
      <div class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#555]">Throughput 24h</div>
      <div class="mt-1 text-sm font-semibold text-[#d9d9de]"><%= completed_count %> tasks done</div>
      <div class="mt-1 text-[11px] text-[#666]"><%= agent.runtime_provider %> runtime</div>
    </div>
  </div>

  <% if alerts.any? %>
    <div class="mt-4 flex flex-wrap items-center gap-2 rounded-xl border <%= agent.last_seen_state == :stale ? 'border-amber-400/20 bg-amber-400/10' : 'border-white/[0.06] bg-white/[0.03]' %> px-3 py-2 text-xs text-[#c9c9ce]">
      <span class="font-semibold <%= agent.last_seen_state == :stale ? 'text-amber-300' : 'text-[#fbbf24]' %>">Attention</span>
      <% alerts.first(2).each do |alert| %>
        <span class="text-[#444]">•</span>
        <span><%= alert %></span>
      <% end %>
      <% if alerts.size > 2 %>
        <span class="text-[#444]">•</span>
        <span class="text-[#888]">+<%= alerts.size - 2 %> more</span>
      <% end %>
    </div>
  <% end %>
</div>
