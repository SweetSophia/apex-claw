<div class="max-w-2xl">
  <div class="text-xs font-semibold text-[#555] uppercase tracking-wider mb-3">Agent Instructions</div>
  <p class="text-xs text-[#666] mb-4">
    Define this agent's role, expertise, and working style. These instructions are injected into the agent's context for every task.
  </p>

  <%= form_with model: agent, url: api_v1_agent_path(agent), method: :patch,
        data: { turbo_frame: "agent_show_instructions_#{agent.id}" } do |f| %>
    <div class="mb-4">
      <%= f.text_area :instructions,
            value: agent.instructions,
            placeholder: "You are a frontend engineer specializing in React and TypeScript...",
            class: "w-full min-h-[200px] rounded-md border border-white/[0.08] bg-white/[0.03] px-3 py-2 text-sm font-mono placeholder:text-[#444] focus:outline-none focus:ring-1 focus:ring-amber-400/50 resize-y" %>
    </div>
    <div class="flex items-center justify-between">
      <span class="text-xs text-[#555]">
        <%= (agent.instructions || "").length %> characters
      </span>
      <%= f.submit "Save Instructions",
            class: "px-3 py-1.5 text-xs font-medium rounded-md bg-amber-400 text-[#161619] hover:bg-amber-500 transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>
