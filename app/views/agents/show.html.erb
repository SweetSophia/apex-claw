<% content_for :title, "#{@agent.name} - Agents - Apex Claw" %>
<% @board_page = false %>

<%= turbo_stream_from "agents:#{current_user.id}" %>

<div class="py-8">
  <%# Breadcrumb %>
  <div class="flex items-center gap-2 text-xs text-[#555] mb-6">
    <%= link_to "Agents", agents_path, class: "hover:text-[#888] transition-colors" %>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
      <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
    </svg>
    <span class="text-[#888]"><%= @agent.name %></span>
  </div>

  <%= render "agents/show_dashboard", agent: @agent %>
</div>
