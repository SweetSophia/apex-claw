<% recent_completed_tasks = agent.claimed_tasks.done.includes(:board).order(completed_at: :desc).limit(10) %>
<div id="agent_show_recent_work_<%= agent.id %>">
  <% if recent_completed_tasks.any? %>
    <div class="mb-8">
      <div class="text-xs font-semibold text-[#555] uppercase tracking-wider mb-3">Recent Completed Work</div>
      <div class="space-y-2">
        <% recent_completed_tasks.each do |task| %>
          <%= link_to board_path(task.board), class: "block p-3 rounded-lg bg-white/[0.03] border border-white/[0.06] hover:bg-white/[0.05] transition-colors" do %>
            <div class="flex items-center justify-between gap-3">
              <div>
                <div class="text-sm font-semibold text-[#e0e0e0]"><%= task.name %></div>
                <div class="text-xs text-[#555] mt-0.5"><%= task.board.name %> · completed <%= time_ago_in_words(task.completed_at) %> ago</div>
              </div>
              <span class="text-[10px] px-2 py-0.5 rounded bg-emerald-500/15 text-emerald-300">Done</span>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
